#
# HDMITX
#
menu "Amlogic HDMITX Module"

config AMLOGIC_HDMITX
	bool "AMLOGIC HDMITX driver"
	select AMLOGIC_HDMITX_COMMON
	default n
	help
	This option is used to configure Amlogic drivers
        of the hdmi tx output

config AMLOGIC_HDMITX_GXX
	bool "AMLOGIC HDMITX driver compile"
	depends on !AMLOGIC_REMOVE_OLD
	default AMLOGIC_HDMITX
	help
	This option is used to compile Amlogic drivers
        of the hdmi tx output

endmenu
