#
# Video output configuration
#
menu "Amlogic LCD Output Module"

config AMLOGIC_LCD
	bool "LCD Output Module"
	default n
	help
		LCD output module
		Include LVDS, MIPI-DPI

config AMLOGIC_LCD_VBYONE
	bool "LCD V-BY-ONE Output Module"
	default n
	depends on AMLOGIC_LCD
	help
		LCD V-BY-ONE output module
		Configure the LCD output model for V-BY-ONE output

config AMLOGIC_LCD_TCON
	bool "LCD TCON Output Module"
	default n
	depends on AMLOGIC_LCD
	help
		LCD tcon output module
		Configure the LCD output model for tcon output

config AMLOGIC_LCD_MIPI_DSI
	bool "LCD MIPI_DSI Output Module"
	default n
	depends on AMLOGIC_LCD
	help
		LCD MIPI_DSI output module
		Configure the LCD output model for MIPI_DSI output

config AMLOGIC_LCD_CLK_SOC
	bool "Control lcd_clk_xxx file to build"
	default AMLOGIC_LCD
	depends on !AMLOGIC_C3_REMOVE
	help
	        Control lcd_clk_xxx file to build with AMLOGIC_C3_REMOVE

if AMLOGIC_LCD
source "$(COMMON_DRIVERS_DIR)/drivers/media/vout/lcd/backlight/Kconfig"
source "$(COMMON_DRIVERS_DIR)/drivers/media/vout/lcd/lcd_extern/Kconfig"
source "$(COMMON_DRIVERS_DIR)/drivers/media/vout/lcd/ambilight/Kconfig"
endif

endmenu
