                "meson_mbox_pl_v2.c",
                "meson_mbox_devfs.c",
                "meson_mbox_sec.c",
            ],
        },
    },
    hdrs = [
        "//common_drivers:soc_headers",
    ],
    local_defines = ["pr_fmt(fmt)=\"[mailbox]: \" fmt"],
    out = "amlogic-mailbox.ko",
    kernel_build = "//common_drivers:amlogic",
    visibility = ["//visibility:public"],
)
