# Generic Trusted Execution Environment Configuration
config AMLOGIC_AMLTEE
	tristate "Trusted Execution Environment support"
	depends on HAVE_ARM_SMCCC || COMPILE_TEST || CPU_SUP_AMD
	select CRYPTO if AMLOGIC_BREAK_GKI
	select CRYPTO_SHA1 if AMLOGIC_BREAK_GKI
	select DMA_SHARED_BUFFER if AMLOGIC_BREAK_GKI
	select GENERIC_ALLOCATOR if AMLOGIC_BREAK_GKI
	help
	  This implements a generic interface towards a Trusted Execution
	  Environment (TEE).

if AMLOGIC_AMLTEE

menu "TEE drivers"

source "$(COMMON_DRIVERS_DIR)/drivers/aml_tee/optee/Kconfig"
endmenu

endif
