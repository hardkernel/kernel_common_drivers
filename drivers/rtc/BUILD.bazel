load("//build/kernel/kleaf:kernel.bzl", "ddk_headers", "ddk_module")
load("//common_drivers:amlogic_utils.bzl", "m_k_files", "kernel_select")

m_k_files()

ddk_module(
    name = "amlogic-rtc",
    srcs = glob([
        "**/*.h",
    ]),
    conditional_srcs = {
        "CONFIG_AMLOGIC_RTC": {
            True: [
                    "main.c",
            ],
        },
        "CONFIG_AMLOGIC_RTC_DRV_MESON_VRTC": {
            True: [
                    "rtc-meson-vrtc.c",
            ],
        },
        "CONFIG_AMLOGIC_MESON_RTC": {
            True: [
                    "meson-rtc.c",
            ],
        },
        "CONFIG_AMLOGIC_RTC_PMIC6B": {
            True: [
                    "meson_pmic6b/pmic6b_rtc.c",
            ],
        },
    },
    hdrs = [
    ],
    local_defines = [
        "pr_fmt(fmt)=\"[rtc]: \" fmt",
    ],
    out = "amlogic-rtc.ko",
    kernel_build = kernel_select(),
    visibility = ["//visibility:public"],
    deps = [
        "//common_drivers/drivers/gki_tool:amlogic-gkitool",
    ],
)
