From dc0b07153192480b8dc3fc99cbfcefbfe159965d Mon Sep 17 00:00:00 2001
From: Tao Zeng <tao.zeng@amlogic.com>
Date: Tue, 9 Apr 2024 12:44:27 +0800
Subject: [PATCH] arm64: support Image.zstd target [1/1]

PD#SWPL-163856

Problem:
not support Image.zstd build target

Solution:
add it

Change-Id: I95a4214fd19a3d6206f972ddc3f318de5b58cc4c
Signed-off-by: Tao Zeng <tao.zeng@amlogic.com>
---
 BUILD.bazel              |  1 +
 arch/arm64/boot/Makefile | 12 +++++++++++-
 2 files changed, 12 insertions(+), 1 deletion(-)

diff --git a/BUILD.bazel b/BUILD.bazel
index 14b3bbedd46fe..5dfc9706c3f6b 100644
--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -27,6 +27,7 @@ _GKI_AARCH64_MAKE_GOALS = [
     "Image",
     "Image.lz4",
     "Image.gz",
+    "Image.zstd",
     "modules",
 ]
 
diff --git a/arch/arm64/boot/Makefile b/arch/arm64/boot/Makefile
index ebe80faab8837..f71519746c4b4 100644
--- a/arch/arm64/boot/Makefile
+++ b/arch/arm64/boot/Makefile
@@ -16,7 +16,7 @@
 
 OBJCOPYFLAGS_Image :=-O binary -R .note -R .note.gnu.build-id -R .comment -S
 
-targets := Image Image.bz2 Image.gz Image.lz4 Image.lzma Image.lzo
+targets := Image Image.bz2 Image.gz Image.lz4 Image.lzma Image.lzo Image.zstd
 
 $(obj)/Image: vmlinux FORCE
 	$(call if_changed,objcopy)
@@ -27,6 +27,16 @@ $(obj)/Image.bz2: $(obj)/Image FORCE
 $(obj)/Image.gz: $(obj)/Image FORCE
 	$(call if_changed,gzip)
 
+ifdef CONFIG_AMLOGIC_AMFC
+$(obj)/Image.zstd: $(obj)/Image FORCE
+	$(ZSTD) -19 $< -o $@
+else
+# use lz4 as fallback to avoid build failed
+# Image.zstd should be only used on soc have AMFC
+$(obj)/Image.zstd: $(obj)/Image FORCE
+	$(call if_changed,lz4)
+endif
+
 $(obj)/Image.lz4: $(obj)/Image FORCE
 	$(call if_changed,lz4)
 
-- 
2.42.0

