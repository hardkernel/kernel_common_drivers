 	for (i = 0; i < NR_CACHED_SCS; i++) {
 		s = this_cpu_xchg(scs_cache[i], NULL);
 		if (s) {
+		#ifndef CONFIG_AMLOGIC_MEMORY_OPT
 			s = kasan_unpoison_vmalloc(s, SCS_SIZE,
