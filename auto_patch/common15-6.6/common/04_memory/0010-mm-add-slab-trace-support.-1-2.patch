From 6aee266219c9a17ce5d9e0b46e6f6c57a1468bc6 Mon Sep 17 00:00:00 2001
From: Jianxiong Pan <jianxiong.pan@amlogic.com>
Date: Thu, 21 Dec 2023 17:05:43 +0800
Subject: [PATCH] mm: add slab trace support. [1/2]

PD#SWPL-150034

Problem:
no slab trace.

Solution:
add slab trace.

Verify:
local.

Change-Id: I91f980cf11397f34b29698d7274da1abeb30906c
Signed-off-by: Jianxiong Pan <jianxiong.pan@amlogic.com>
---
 mm/slub.c | 41 +++++++++++++++++++++++++++++++++++++++++
 1 file changed, 41 insertions(+)

diff --git a/mm/slub.c b/mm/slub.c
index 9b403b3f0833..a7bec9180bde 100644
--- a/mm/slub.c
+++ b/mm/slub.c
@@ -50,6 +50,9 @@
 #ifdef CONFIG_AMLOGIC_MEMORY_EXTEND
 #include <linux/amlogic/memory.h>
 #endif
+#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+#include <linux/amlogic/slab_trace.h>
+#endif
 /*
  * Lock order:
  *   1. slab_mutex (Global Mutex)
@@ -2030,6 +2033,9 @@ static struct slab *allocate_slab(struct kmem_cache *s, gfp_t flags, int node)
 			return NULL;
 		stat(s, ORDER_FALLBACK);
 	}
+#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+	slab_trace_add_page(slab_folio(slab), oo_order(oo), s, alloc_gfp);
+#endif
 
 	slab->objects = oo_objects(oo);
 	slab->inuse = 0;
@@ -2087,6 +2093,9 @@ static void __free_slab(struct kmem_cache *s, struct slab *slab)
 	__folio_clear_slab(folio);
 	mm_account_reclaimed_pages(pages);
 	unaccount_slab(slab, order, s);
+#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+	slab_trace_remove_page(&folio->page, order, s);
+#endif
 	__free_pages(&folio->page, order);
 }
 
@@ -3176,6 +3185,9 @@ static void *___slab_alloc(struct kmem_cache *s, gfp_t gfpflags, int node,
 	c->freelist = get_freepointer(s, freelist);
 	c->tid = next_tid(c->tid);
 	local_unlock_irqrestore(&s->cpu_slab->lock, flags);
+#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+	slab_trace_mark_object(freelist, addr, s);
+#endif
 	return freelist;
 
 deactivate_slab:
@@ -3241,6 +3253,9 @@ static void *___slab_alloc(struct kmem_cache *s, gfp_t gfpflags, int node,
 
 		if (s->flags & SLAB_STORE_USER)
 			set_track(s, freelist, TRACK_ALLOC, addr);
+	#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+		slab_trace_mark_object(freelist, addr, s);
+	#endif
 
 		return freelist;
 	}
@@ -3267,6 +3282,9 @@ static void *___slab_alloc(struct kmem_cache *s, gfp_t gfpflags, int node,
 		if (s->flags & SLAB_STORE_USER)
 			set_track(s, freelist, TRACK_ALLOC, addr);
 
+	#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+		slab_trace_mark_object(freelist, addr, s);
+	#endif
 		return freelist;
 	}
 
@@ -3276,6 +3294,9 @@ static void *___slab_alloc(struct kmem_cache *s, gfp_t gfpflags, int node,
 		 * we don't make further mismatched allocations easier.
 		 */
 		deactivate_slab(s, slab, get_freepointer(s, freelist));
+	#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+		slab_trace_mark_object(freelist, addr, s);
+	#endif
 		return freelist;
 	}
 
@@ -3399,6 +3420,9 @@ static __always_inline void *__slab_alloc_node(struct kmem_cache *s,
 		}
 		prefetch_freepointer(s, next_object);
 		stat(s, ALLOC_FASTPATH);
+	#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+		slab_trace_mark_object(object, addr, s);
+	#endif
 	}
 
 	return object;
@@ -3756,6 +3780,10 @@ static __always_inline void do_slab_free(struct kmem_cache *s,
 	/* Same with comment on barrier() in slab_alloc_node() */
 	barrier();
 
+#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+	slab_trace_remove_object(head, s);
+#endif
+
 	if (unlikely(slab != c->slab)) {
 		__slab_free(s, slab, head, tail_obj, cnt, addr);
 		return;
@@ -3869,6 +3897,9 @@ int build_detached_freelist(struct kmem_cache *s, size_t size,
 	if (!s) {
 		/* Handle kalloc'ed objects */
 		if (unlikely(!folio_test_slab(folio))) {
+		#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+			slab_trace_remove_page(&folio->page, folio_order(folio), s);
+		#endif
 			free_large_kmalloc(folio, object);
 			df->slab = NULL;
 			return size;
@@ -4513,6 +4544,13 @@ static int calculate_sizes(struct kmem_cache *s)
 	return !!oo_objects(s->oo);
 }
 
+#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+int get_cache_max_order(struct kmem_cache *s)
+{
+	return oo_order(s->oo);
+}
+#endif
+
 static int kmem_cache_open(struct kmem_cache *s, slab_flags_t flags)
 {
 	s->flags = kmem_cache_flags(s->size, flags, s->name);
@@ -5068,6 +5106,9 @@ void __init kmem_cache_init(void)
 	/* Now we can use the kmem_cache to allocate kmalloc slabs */
 	setup_kmalloc_cache_index_table();
 	create_kmalloc_caches(0);
+#ifdef CONFIG_AMLOGIC_SLAB_TRACE
+	slab_trace_init();
+#endif
 
 	/* Setup random freelists for each cache */
 	init_freelist_randomization();
-- 
2.42.0

