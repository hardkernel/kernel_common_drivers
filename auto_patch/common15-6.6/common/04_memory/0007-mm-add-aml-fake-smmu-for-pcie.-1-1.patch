From 7a43afd9fbc4d54bb38fc7c746574c599ed24423 Mon Sep 17 00:00:00 2001
From: Jianxiong Pan <jianxiong.pan@amlogic.com>
Date: Thu, 21 Dec 2023 14:27:48 +0800
Subject: [PATCH] mm: add aml fake smmu for pcie. [1/2]

PD#SWPL-150034

Problem:
support pcie white list.

Solution:
add aml fake smmu for pcie.

Verify:
local.

Change-Id: Ia26007f74064501f25a5a6f02ae15e2e48d84b9f
Signed-off-by: Jianxiong Pan <jianxiong.pan@amlogic.com>
---
 arch/arm/mm/dma-mapping.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/arch/arm/mm/dma-mapping.c b/arch/arm/mm/dma-mapping.c
index ee736b9082f1..912e374a750c 100644
--- a/arch/arm/mm/dma-mapping.c
+++ b/arch/arm/mm/dma-mapping.c
@@ -34,6 +34,9 @@
 #include <asm/mach/map.h>
 #include <asm/system_info.h>
 #include <asm/xen/xen-ops.h>
+#ifdef CONFIG_AMLOGIC_PCIE_DMA_OPS
+#include <linux/amlogic/dma_pcie_mapping.h>
+#endif
 
 #include "dma.h"
 #include "mm.h"
@@ -1736,6 +1739,11 @@ static void arm_setup_iommu_dma_ops(struct device *dev, u64 dma_base, u64 size,
 	}
 
 	set_dma_ops(dev, &iommu_ops);
+
+#ifdef CONFIG_AMLOGIC_PCIE_DMA_OPS
+	if (dev->bus && dev->bus->name && !strcmp(dev->bus->name, "pci"))
+		set_dma_ops(dev, &aml_pcie_dma_ops);
+#endif
 }
 
 static void arm_teardown_iommu_dma_ops(struct device *dev)
-- 
2.42.0

