From e78cc754fcb7e6413f57479b2703c3bacf2b377e Mon Sep 17 00:00:00 2001
From: Wanwei Jiang <wanwei.jiang@amlogic.com>
Date: Fri, 17 Mar 2023 17:35:31 +0800
Subject: [PATCH] bazel: support use bazel tool to build [1/1]

PD#SWPL-112151

Problem:
support use bazel tool to build

Solution:
support use bazel tool to build

Verify:
sc2

Change-Id: I96e80b97ed481f32239955748ffa52e7d40a85aa
Signed-off-by: Wanwei Jiang <wanwei.jiang@amlogic.com>
---
 BUILD.bazel            | 3 +++
 build.config.constants | 1 +
 modules.bzl            | 6 ++++++
 3 files changed, 10 insertions(+)

diff --git a/BUILD.bazel b/BUILD.bazel
index 17884047157e..cde3a50f6dbc 100644
--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -2413,3 +2413,6 @@ pkg_files(
     renames = {file: file for file in _TEST_MAPPINGS},
     visibility = ["//kernel/tests/test_mappings:__pkg__"],
 )
+
+load("//common:common_drivers/amlogic.bzl", "define_amlogic")
+define_amlogic()
diff --git a/build.config.constants b/build.config.constants
index 3ffacbcbee63..21309d2d4d20 100644
--- a/build.config.constants
+++ b/build.config.constants
@@ -1,3 +1,4 @@
+BRANCH=android15-6.6
 CLANG_VERSION=r510928
 RUSTC_VERSION=1.73.0
 AARCH64_NDK_TRIPLE=aarch64-linux-android31
diff --git a/modules.bzl b/modules.bzl
index 45457a64f938..ad03780b8f52 100644
--- a/modules.bzl
+++ b/modules.bzl
@@ -6,6 +6,8 @@ This module contains a full list of kernel modules
  compiled by GKI.
 """
 
+load("//common:common_drivers/modules.bzl", "ALL_MODULES_REMOVE")
+
 _COMMON_GKI_MODULES_LIST = [
     # keep sorted
     "drivers/block/zram/zram.ko",
@@ -129,4 +131,8 @@ def get_gki_modules_list(arch = None):
             arch,
         ))
 
+    remove_modules_items = {module: None for module in depset(ALL_MODULES_REMOVE).to_list()}
+    gki_modules_list = [module for module in depset(gki_modules_list).to_list() if module not in remove_modules_items] \
+			if remove_modules_items else gki_modules_list
+
     return gki_modules_list
-- 
