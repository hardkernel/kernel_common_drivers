From 28ea91027b889b05150219d4e332fd9176b3ccbf Mon Sep 17 00:00:00 2001
From: Ashay Jaiswal <quic_ashayj@quicinc.com>
Date: Tue, 21 Sep 2021 23:39:24 +0530
Subject: [PATCH] Revert "Revert "ANDROID: Sched: Add restricted vendor hooks
 for scheduler""

This reverts commit 627a494ef3370e8dcb10938f2e7a67b79cf0a28a.
Reverting commit to add the vendor hooks back, this is to facilitate
various scheduler value adds.

Bug: 200103201
Change-Id: Ifbd7d235f863e01848c22b8185c4ec94da8c862c
Signed-off-by: Ashay Jaiswal <quic_ashayj@quicinc.com>
---
 include/trace/hooks/sched.h | 4 ++++
 kernel/sched/core.c         | 1 +
 kernel/sched/vendor_hooks.c | 1 +
 3 files changed, 6 insertions(+)

diff --git a/include/trace/hooks/sched.h b/include/trace/hooks/sched.h
index 20255a477947..98524afccf85 100644
--- a/include/trace/hooks/sched.h
+++ b/include/trace/hooks/sched.h
@@ -255,6 +255,10 @@ DECLARE_HOOK(android_vh_set_wake_flags,
 	TP_PROTO(int *wake_flags, unsigned int *mode),
 	TP_ARGS(wake_flags, mode));
 
+DECLARE_RESTRICTED_HOOK(android_rvh_tick_entry,
+	TP_PROTO(struct rq *rq),
+	TP_ARGS(rq), 1);
+
 /* macro versions of hooks are no longer required */
 
 #endif /* _TRACE_HOOK_SCHED_H */
diff --git a/kernel/sched/core.c b/kernel/sched/core.c
index 2c13df4b87dc..251d8ce36c77 100644
--- a/kernel/sched/core.c
+++ b/kernel/sched/core.c
@@ -5738,6 +5738,7 @@ void scheduler_tick(void)
 	rq_lock(rq, &rf);
 
 	update_rq_clock(rq);
+	trace_android_rvh_tick_entry(rq);
 
 	thermal_pressure = arch_scale_thermal_pressure(cpu_of(rq));
 	update_thermal_load_avg(rq_clock_thermal(rq), rq, thermal_pressure);
diff --git a/kernel/sched/vendor_hooks.c b/kernel/sched/vendor_hooks.c
index 0838a1b58ac4..ed8137b4d98a 100644
--- a/kernel/sched/vendor_hooks.c
+++ b/kernel/sched/vendor_hooks.c
@@ -67,3 +67,4 @@ EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_update_topology_flags_workfn);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_update_thermal_stats);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_do_wake_up_sync);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_set_wake_flags);
+EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_tick_entry);
-- 
2.41.0

