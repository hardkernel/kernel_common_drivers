From a317f2ad4d3350718c643d423a85d95dbb7be044 Mon Sep 17 00:00:00 2001
From: Wanwei Jiang <wanwei.jiang@amlogic.com>
Date: Fri, 24 Nov 2023 22:14:58 +0800
Subject: [PATCH] vendor hook: support schedule vendor hook [1/1]

PD#SWPL-145682

Problem:
support schedule vendor hook

Solution:
support schedule vendor hook

Verify:
local

Change-Id: I08ccc1596ef3568367dc29429b002dfd556a3d00
---
 include/trace/hooks/sched.h | 4 ++++
 kernel/sched/core.c         | 1 +
 kernel/sched/vendor_hooks.c | 1 +
 3 files changed, 6 insertions(+)

diff --git a/include/trace/hooks/sched.h b/include/trace/hooks/sched.h
index 98524afccf85..b3b4bfeb7527 100644
--- a/include/trace/hooks/sched.h
+++ b/include/trace/hooks/sched.h
@@ -136,6 +136,10 @@ DECLARE_RESTRICTED_HOOK(android_rvh_ttwu_cond,
 	TP_PROTO(int cpu, bool *cond),
 	TP_ARGS(cpu, cond), 1);
 
+DECLARE_RESTRICTED_HOOK(android_rvh_schedule,
+	TP_PROTO(struct task_struct *prev, struct task_struct *next, struct rq *rq),
+	TP_ARGS(prev, next, rq), 1);
+
 DECLARE_RESTRICTED_HOOK(android_rvh_schedule_bug,
 	TP_PROTO(void *unused),
 	TP_ARGS(unused), 1);
diff --git a/kernel/sched/core.c b/kernel/sched/core.c
index 251d8ce36c77..faee6cef0b71 100644
--- a/kernel/sched/core.c
+++ b/kernel/sched/core.c
@@ -6755,6 +6755,7 @@ static void __sched notrace __schedule(unsigned int sched_mode)
 	rq->last_seen_need_resched_ns = 0;
 #endif
 
+	trace_android_rvh_schedule(prev, next, rq);
 	if (likely(prev != next)) {
 		rq->nr_switches++;
 		/*
diff --git a/kernel/sched/vendor_hooks.c b/kernel/sched/vendor_hooks.c
index ed8137b4d98a..4073938f68c7 100644
--- a/kernel/sched/vendor_hooks.c
+++ b/kernel/sched/vendor_hooks.c
@@ -62,6 +62,7 @@ EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_do_sched_yield);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_sched_fork_init);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_ttwu_cond);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_schedule_bug);
+EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_schedule);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_sched_exec);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_update_topology_flags_workfn);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_update_thermal_stats);
