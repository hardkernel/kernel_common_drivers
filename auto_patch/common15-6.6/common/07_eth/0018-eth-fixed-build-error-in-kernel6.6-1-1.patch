From 94738c9b5ab2844e41ee193f1b3ba1b5a8c3e532 Mon Sep 17 00:00:00 2001
From: Wanwei Jiang <wanwei.jiang@amlogic.com>
Date: Wed, 22 Nov 2023 15:55:49 +0800
Subject: [PATCH] eth: fixed build error in kernel6.6 [1/1]

PD#SWPL-145682

Problem:
build error

Solution:
fixed build error in kernel6.6

Verify:
local

Change-Id: Ib58a9ed969148b0f69b3eae438288cfd60cb03e2
---
 drivers/net/ethernet/stmicro/stmmac/dwmac-meson8b.c | 7 ++-----
 1 file changed, 2 insertions(+), 5 deletions(-)

diff --git a/drivers/net/ethernet/stmicro/stmmac/dwmac-meson8b.c b/drivers/net/ethernet/stmicro/stmmac/dwmac-meson8b.c
index 9998041a781e..4efc48608ad7 100644
--- a/drivers/net/ethernet/stmicro/stmmac/dwmac-meson8b.c
+++ b/drivers/net/ethernet/stmicro/stmmac/dwmac-meson8b.c
@@ -778,19 +778,16 @@ static void meson8b_dwmac_remove(struct platform_device *pdev)
 {
 	struct net_device *ndev = platform_get_drvdata(pdev);
 	struct stmmac_priv *priv = netdev_priv(ndev);
-	int err;
 
 	struct meson8b_dwmac *dwmac = get_stmmac_bsp_priv(&pdev->dev);
 
 	input_unregister_device(dwmac->input_dev);
 
-	err = stmmac_dvr_remove(&pdev->dev);
-	if (err < 0)
-		dev_err(&pdev->dev, "failed to remove platform: %d\n", err);
+	stmmac_dvr_remove(&pdev->dev);
 
 	stmmac_remove_config_dt(pdev, priv->plat);
 
-	return err;
+	return;
 }
 
 static SIMPLE_DEV_PM_OPS(meson8b_pm_ops,
