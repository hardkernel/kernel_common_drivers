From 8e5b1c48eecc70b283bce4caf0af3b2c87d20b06 Mon Sep 17 00:00:00 2001
From: Hanjie Lin <hanjie.lin@amlogic.com>
Date: Thu, 25 May 2023 16:59:40 +0800
Subject: [PATCH 9/9] arm: disable OPTPROBES and noinline handle_pte_fault
 [1/1]

PD#SWPL-121806

Problem:
arm OPTPROBES will cause kprobe handler unexpected behavior
memory atrace need kprobe at handle_pte_fault()

Solution:
disable HAVE_OPTPROBES and noinline handle_pte_fault

Verify:
sc2

Change-Id: I4efbec5aeeb7b6fe56f6fbd0d413bae123549c5a
Signed-off-by: Hanjie Lin <hanjie.lin@amlogic.com>
---
 arch/arm/Kconfig | 2 +-
 mm/memory.c      | 4 ++++
 2 files changed, 5 insertions(+), 1 deletion(-)

diff --git a/arch/arm/Kconfig b/arch/arm/Kconfig
index 9557808e8937..abdd89e76df5 100644
--- a/arch/arm/Kconfig
+++ b/arch/arm/Kconfig
@@ -113,7 +113,7 @@ config ARM
 	select HAVE_KRETPROBES if HAVE_KPROBES
 	select HAVE_MOD_ARCH_SPECIFIC
 	select HAVE_NMI
-	select HAVE_OPTPROBES if !THUMB2_KERNEL
+	select HAVE_OPTPROBES if !THUMB2_KERNEL && (AMLOGIC_DEBUG != y && AMLOGIC_DEBUG != m)
 	select HAVE_PCI if MMU
 	select HAVE_PERF_EVENTS
 	select HAVE_PERF_REGS
diff --git a/mm/memory.c b/mm/memory.c
index bbbe34100f3c..a76bed01cc73 100644
--- a/mm/memory.c
+++ b/mm/memory.c
@@ -4945,7 +4945,11 @@ static vm_fault_t wp_huge_pud(struct vm_fault *vmf, pud_t orig_pud)
  * The mmap_lock may have been released depending on flags and our return value.
  * See filemap_fault() and __folio_lock_or_retry().
  */
+#if (defined CONFIG_ARM) && IS_ENABLED(CONFIG_AMLOGIC_DEBUG_ATRACE)
+vm_fault_t handle_pte_fault(struct vm_fault *vmf)
+#else
 static vm_fault_t handle_pte_fault(struct vm_fault *vmf)
+#endif
 {
 	pte_t entry;
 
-- 
2.41.0

