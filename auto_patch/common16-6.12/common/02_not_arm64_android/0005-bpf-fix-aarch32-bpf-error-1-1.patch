From 59f2365bcf24d9dedbf5b0dc2a7d0636daeb9caf Mon Sep 17 00:00:00 2001
From: "qinglin.li" <qinglin.li@amlogic.com>
Date: Wed, 29 Oct 2025 19:31:06 +0800
Subject: [PATCH] bpf: fix aarch32 bpf error [1/1]

PD#SWPL-234739

Problem:
case BPF_STX | BPF_ATOMIC | BPF_W arm return fail
due to prog->jited is 0 but fp->jit_requested not reset 0

Solution:
defalt fp->jit_requested false when arm

Verify:
local

Change-Id: Id8dc29a8204b91fc9298acc664227d8fe72cd100
Signed-off-by: qinglin.li <qinglin.li@amlogic.com>
---
 kernel/bpf/core.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/kernel/bpf/core.c b/kernel/bpf/core.c
index 18d79fbd753a5..50667f97d4748 100644
--- a/kernel/bpf/core.c
+++ b/kernel/bpf/core.c
@@ -2435,7 +2435,11 @@ struct bpf_prog *bpf_prog_select_runtime(struct bpf_prog *fp, int *err)
 	/* In case of BPF to BPF calls, verifier did all the prep
 	 * work with regards to JITing, etc.
 	 */
+#if IS_ENABLED(CONFIG_AMLOGIC_ARMV8_AARCH32)
+	bool jit_needed = false;
+#else
 	bool jit_needed = fp->jit_requested;
+#endif
 
 	if (fp->bpf_func)
 		goto finalize;
-- 
2.50.1

