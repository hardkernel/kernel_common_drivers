From 5f56629b2527a0f0e385ea480e091adba27071e6 Mon Sep 17 00:00:00 2001
From: "dongqing.li" <dongqing.li@amlogic.com>
Date: Tue, 22 Oct 2024 11:21:32 +0000
Subject: [PATCH] ramdump: set TEXT_OFFSET=0x02008000 for ker6.12-u32 [1/1]

PD#SWPL-182182

Problem:
The .text addr of Kernel 32bit is 0. When enabling the
ramdump, it needs to be offset to 24MB+.

Solution:
1. modify textofs-y := 0x02008000, LOADADDR=0x02008000
2. enable for .ko link error: CONFIG_ARM_MODULE_PLTS
3. disable AUTO_ZRELADDR (less than 128MB, not necessary)
4. enable for gdb debug: CONFIG_AMLOGIC_RAMDUMP, CONFIG_KALLSYMS,
CONFIG_KALLSYMS_ALL, CONFIG_DEBUG_INFO, CONFIG_FRAME_POINTER,
CONFIG_DEBUG_KERNEL
5. add trace_android_vh_ipi_stop() for ker 32bit IPI_STOP.

Verify:
A1

Change-Id: I2e56a07fc3c4443d08085a57519c41bff8daa453
Signed-off-by: dongqing.li <dongqing.li@amlogic.com>
---
 arch/arm/Makefile               |  1 +
 arch/arm/boot/Makefile          | 13 +++++++++++++
 arch/arm/boot/compressed/head.S |  5 +++++
 arch/arm/kernel/head.S          | 10 ++++++++++
 arch/arm/kernel/smp.c           |  8 ++++++++
 5 files changed, 37 insertions(+)

diff --git a/arch/arm/Makefile b/arch/arm/Makefile
index aafebf145738..7f57731021f7 100644
--- a/arch/arm/Makefile
+++ b/arch/arm/Makefile
@@ -168,6 +168,7 @@ endif
 textofs-$(CONFIG_ARCH_QCOM_RESERVE_SMEM) := 0x00208000
 textofs-$(CONFIG_ARCH_MESON) := 0x00208000
 textofs-$(CONFIG_ARCH_AXXIA) := 0x00308000
+textofs-$(CONFIG_AMLOGIC_RAMDUMP_TEXTOFFSET) := 0x02008000
 
 # Machine directory name.  This list is sorted alphanumerically
 # by CONFIG_* macro name.
diff --git a/arch/arm/boot/Makefile b/arch/arm/boot/Makefile
index ba9b9a802469..868221feffa6 100644
--- a/arch/arm/boot/Makefile
+++ b/arch/arm/boot/Makefile
@@ -12,6 +12,19 @@
 #
 OBJCOPYFLAGS	:=-O binary -R .comment -S
 
+ifeq ($(CONFIG_AMLOGIC_RAMDUMP_TEXTOFFSET),y)
+zreladdr-y       += 0x02008000
+params_phys-y    := 0x02000100
+initrd_phys-y    := 0x02900000
+# Note: the following conditions must always be true:
+#   ZRELADDR == virt_to_phys(PAGE_OFFSET + TEXT_OFFSET)
+#   PARAMS_PHYS must be within 4MB of ZRELADDR
+#   INITRD_PHYS must be in RAM
+ZRELADDR    := $(zreladdr-y)
+PARAMS_PHYS := $(params_phys-y)
+INITRD_PHYS := $(initrd_phys-y)
+endif
+
 #   ZRELADDR == virt_to_phys(PAGE_OFFSET + TEXT_OFFSET)
 ifdef CONFIG_PHYS_OFFSET
 add_hex = $(shell printf 0x%x $$(( $(1) + $(2) )) )
diff --git a/arch/arm/boot/compressed/head.S b/arch/arm/boot/compressed/head.S
index 9f406e9c0ea6..cc2ef4c29e1d 100644
--- a/arch/arm/boot/compressed/head.S
+++ b/arch/arm/boot/compressed/head.S
@@ -309,7 +309,12 @@ not_angel:
 1:
 #endif /* CONFIG_USE_OF */
 		/* Determine final kernel image address. */
+#ifdef CONFIG_AMLOGIC_RAMDUMP_TEXTOFFSET
+		ldr	r3, =TEXT_OFFSET
+		add	r4, r0, r3
+#else
 		add	r4, r0, #TEXT_OFFSET
+#endif
 #else
 		ldr	r4, =zreladdr
 #endif
diff --git a/arch/arm/kernel/head.S b/arch/arm/kernel/head.S
index 1ec35f065617..2edd660fd8e3 100644
--- a/arch/arm/kernel/head.S
+++ b/arch/arm/kernel/head.S
@@ -65,7 +65,12 @@ kernel_sec_end:
 	.popsection
 
 	.macro	pgtbl, rd, phys
+#ifdef CONFIG_AMLOGIC_RAMDUMP_TEXTOFFSET
+	ldr	r3, =TEXT_OFFSET
+	add	\rd, \phys, r3
+#else
 	add	\rd, \phys, #TEXT_OFFSET
+#endif
 	sub	\rd, \rd, #PG_DIR_SIZE
 	.endm
 
@@ -120,7 +125,12 @@ ENTRY(stext)
 
 #ifndef CONFIG_XIP_KERNEL
 	adr_l	r8, _text			@ __pa(_text)
+#ifdef CONFIG_AMLOGIC_RAMDUMP_TEXTOFFSET
+	ldr	r3, =TEXT_OFFSET
+	sub	r8, r8, r3
+#else
 	sub	r8, r8, #TEXT_OFFSET		@ PHYS_OFFSET
+#endif
 #else
 	ldr	r8, =PLAT_PHYS_OFFSET		@ always constant in this case
 #endif
diff --git a/arch/arm/kernel/smp.c b/arch/arm/kernel/smp.c
index 4a50af78df7e..306b5da28c23 100644
--- a/arch/arm/kernel/smp.c
+++ b/arch/arm/kernel/smp.c
@@ -54,6 +54,11 @@ EXPORT_TRACEPOINT_SYMBOL_GPL(ipi_raise);
 EXPORT_TRACEPOINT_SYMBOL_GPL(ipi_entry);
 EXPORT_TRACEPOINT_SYMBOL_GPL(ipi_exit);
 
+#ifdef CONFIG_AMLOGIC_RAMDUMP
+#undef CREATE_TRACE_POINTS
+#include <trace/hooks/debug.h>
+#endif
+
 /*
  * as from 2.5, kernels no longer have an init_tasks structure
  * so we need some other way of telling a new secondary core
@@ -664,6 +669,9 @@ static void do_handle_IPI(int ipinr)
 		break;
 
 	case IPI_CPU_STOP:
+#ifdef CONFIG_AMLOGIC_RAMDUMP
+		trace_android_vh_ipi_stop(get_irq_regs());
+#endif
 		ipi_cpu_stop(cpu);
 		break;
 
-- 
2.46.0

