From 78d25a5f077682e031099b25aff7eab7510c6c54 Mon Sep 17 00:00:00 2001
From: "jing.li1" <jing.li1@amlogic.com>
Date: Tue, 24 Sep 2024 15:31:12 +0800
Subject: [PATCH] demux: demux support dma buffer on kernel 6.6 [1/1]

PD#SWPL-186953

Problem:
there are compile errors on kernel 6.6 because of missing dma buffer

Solution:
update demux driver to support dma buffer on kernel 6.6

Verify:
sc2

Change-Id: If660cd1845bdeebf11c029c4b084ab1361779b11
Signed-off-by: jing.li1 <jing.li1@amlogic.com>
---
 drivers/media/dvb-core/dmxdev.c      | 14 ++++++++++++++
 include/media/aml_demux_ext.h        |  4 ++++
 include/uapi/linux/dvb/aml_dmx_ext.h | 29 +++++++++++++++++++++++++++-
 3 files changed, 46 insertions(+), 1 deletion(-)

diff --git a/drivers/media/dvb-core/dmxdev.c b/drivers/media/dvb-core/dmxdev.c
index 1d138e8d08f2..7ae03eae49fc 100644
--- a/drivers/media/dvb-core/dmxdev.c
+++ b/drivers/media/dvb-core/dmxdev.c
@@ -1215,6 +1215,20 @@ static int dvb_demux_do_ioctl(struct file *file,
 		}
 		ret = dmx_ext->decode_info(dmxdev->demux, parg);
 		break;
+	case DMX_GET_DMA_BUF_FD:
+		if (!dmx_ext->get_dma_buf_fd) {
+			ret = -EINVAL;
+			break;
+		}
+		ret = dmx_ext->get_dma_buf_fd(dmxdev->demux, parg);
+		break;
+	case DMX_GET_DMA_BUF_INFO:
+		if (!dmx_ext->get_dma_buf_info) {
+			ret = -EINVAL;
+			break;
+		}
+		ret = dmx_ext->get_dma_buf_info(dmxdev->demux, parg);
+		break;
 #endif
 
 	case DMX_ADD_PID:
diff --git a/include/media/aml_demux_ext.h b/include/media/aml_demux_ext.h
index 971d61e11324..ced19a8a5d01 100644
--- a/include/media/aml_demux_ext.h
+++ b/include/media/aml_demux_ext.h
@@ -30,6 +30,10 @@ struct dmx_demux_ext {
 			u16 pids[2]);
 	int (*decode_info)(struct dmx_demux *demux,
 		void *info);
+	int (*get_dma_buf_fd)(struct dmx_demux *demux,
+		void *info);
+	int (*get_dma_buf_info)(struct dmx_demux *demux,
+		void *info);
 };
 
 #endif
diff --git a/include/uapi/linux/dvb/aml_dmx_ext.h b/include/uapi/linux/dvb/aml_dmx_ext.h
index 9f32428478ab..8a6a38e5202a 100644
--- a/include/uapi/linux/dvb/aml_dmx_ext.h
+++ b/include/uapi/linux/dvb/aml_dmx_ext.h
@@ -197,6 +197,30 @@ struct decoder_mem_info {
 	__u32 rp_phy;
 };
 
+/*for dma buf*/
+struct dmx_dma_buf_sec_es_data {
+	__u32 magic_num;
+	__u8 pts_dts_flag;
+	__u64 video_pts;
+	__u64 video_dts;
+	__u64 buf_start;
+	__u64 buf_end;
+	__u64 data_start;
+	__u64 data_end;
+	__u64 buf_rp;
+	__u64 av_handle;
+	__u32 token;
+	__u64 extend_addr;
+	__u32 extend_size;
+};
+
+struct dmx_dma_buf_info {
+	__u64 paddr;
+	__u32 size;
+	__u32 handle;
+	__u32 fd;
+	struct dmx_dma_buf_sec_es_data dmxes;
+};
 /* amlogic define end */
 
 /* amlogic define */
@@ -209,7 +233,10 @@ struct decoder_mem_info {
 #define DMX_SET_SEC_MEM			_IOW('o', 85, struct dmx_sec_mem)
 #define DMX_GET_DVR_MEM			_IOR('o', 86, struct dvr_mem_info)
 #define DMX_REMAP_PID			_IOR('o', 87, __u16[2])
-#define DMX_SET_DECODE_INFO     _IOW('o', 88, struct decoder_mem_info)
+#define DMX_SET_DECODE_INFO     	_IOW('o', 88, struct decoder_mem_info)
+/*for dma buf*/
+#define DMX_GET_DMA_BUF_FD		_IOWR('o', 90, struct dmx_dma_buf_info)
+#define DMX_GET_DMA_BUF_INFO		_IOWR('o', 91, struct dmx_dma_buf_info)
 /* amlogic define end */
 
 #endif
-- 
2.46.0

