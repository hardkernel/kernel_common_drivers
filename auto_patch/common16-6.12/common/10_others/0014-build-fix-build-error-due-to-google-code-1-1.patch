From b4525d8a7e7b4e36268fb65ab5e75585cf751d62 Mon Sep 17 00:00:00 2001
From: "qinglin.li" <qinglin.li@amlogic.com>
Date: Tue, 11 Feb 2025 10:45:53 +0800
Subject: [PATCH] build: fix build error due to google code [1/1]

PD#SWPL-201584

Problem:
build error when CONFIG_F2FS_UNFAIR_RWSEM disabled

Solution:
_trace_android_rvh_f2fs_down_read add Marco control

Verify:
local

Change-Id: I06c445c64e217144737d64e3716e3f18863682bf
Signed-off-by: qinglin.li <qinglin.li@amlogic.com>
---
 fs/f2fs/f2fs.h | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/fs/f2fs/f2fs.h b/fs/f2fs/f2fs.h
index 8d7e3c75f686..65858edee9a0 100644
--- a/fs/f2fs/f2fs.h
+++ b/fs/f2fs/f2fs.h
@@ -2191,7 +2191,9 @@ void _trace_android_rvh_f2fs_down_read(wait_queue_head_t *read_waiters,
 static inline void f2fs_down_read(struct f2fs_rwsem *sem)
 {
 	bool skip = false;
+#ifdef CONFIG_F2FS_UNFAIR_RWSEM
 	_trace_android_rvh_f2fs_down_read(&sem->read_waiters, &sem->internal_rwsem, &skip);
+#endif
 	if (skip)
 		return;
 #ifdef CONFIG_F2FS_UNFAIR_RWSEM
-- 
2.42.0

