From a7c9d173f3ddceb18c026a200b9bab92b9b18c0b Mon Sep 17 00:00:00 2001
From: "qinglin.li" <qinglin.li@amlogic.com>
Date: Fri, 25 Oct 2024 16:55:44 +0800
Subject: [PATCH] ddr_tools: add ddr_tools use vendor_hooks [1/1]

PD#SWPL-188342

Problem:
add ddr_tools use vendor_hooks

Solution:
add android_rvh_arm64_serror_panic
add android_rvh_do_sea

Verify:
local

Change-Id: I38a60910491dc398332aecc623d2de4c4f0be8b9
Signed-off-by: qinglin.li <qinglin.li@amlogic.com>
---
 arch/arm64/kernel/traps.c      |  4 ++++
 arch/arm64/mm/fault.c          |  3 +++
 drivers/android/vendor_hooks.c |  4 ++++
 include/trace/hooks/fault.h    | 15 +++++++++++++++
 include/trace/hooks/traps.h    | 18 ++++++++++++++++++
 5 files changed, 44 insertions(+)
 create mode 100644 include/trace/hooks/fault.h
 create mode 100644 include/trace/hooks/traps.h

diff --git a/arch/arm64/kernel/traps.c b/arch/arm64/kernel/traps.c
index 92a9f18049bf..4856111145e3 100644
--- a/arch/arm64/kernel/traps.c
+++ b/arch/arm64/kernel/traps.c
@@ -49,6 +49,8 @@
 #include <asm/system_misc.h>
 #include <asm/sysreg.h>
 
+#include <trace/hooks/traps.h>
+
 #ifdef CONFIG_AMLOGIC_USER_FAULT
 #include <linux/amlogic/user_fault.h>
 #endif
@@ -950,6 +952,8 @@ void __noreturn arm64_serror_panic(struct pt_regs *regs, unsigned long esr)
 
 	pr_crit("SError Interrupt on CPU%d, code 0x%016lx -- %s\n",
 		smp_processor_id(), esr, esr_get_class_string(esr));
+
+	trace_android_rvh_arm64_serror_panic(regs, esr);
 	if (regs)
 		__show_regs(regs);
 
diff --git a/arch/arm64/mm/fault.c b/arch/arm64/mm/fault.c
index ca436aa0abb1..97b68a80adca 100644
--- a/arch/arm64/mm/fault.c
+++ b/arch/arm64/mm/fault.c
@@ -44,6 +44,8 @@
 #include <asm/tlbflush.h>
 #include <asm/traps.h>
 
+#include <trace/hooks/fault.h>
+
 #ifdef CONFIG_AMLOGIC_USER_FAULT
 #include <linux/amlogic/user_fault.h>
 #endif
@@ -790,6 +792,7 @@ static int do_sea(unsigned long far, unsigned long esr, struct pt_regs *regs)
 		 */
 		siaddr  = untagged_addr(far);
 	}
+	trace_android_rvh_do_sea(siaddr, esr, regs);
 	arm64_notify_die(inf->name, regs, inf->sig, inf->code, siaddr, esr);
 
 	return 0;
diff --git a/drivers/android/vendor_hooks.c b/drivers/android/vendor_hooks.c
index 03be03e0e479..1d583ab2c185 100755
--- a/drivers/android/vendor_hooks.c
+++ b/drivers/android/vendor_hooks.c
@@ -37,6 +37,8 @@
 #include <trace/hooks/fpsimd.h>
 #include <trace/hooks/dtask.h>
 #include <trace/hooks/ftrace_dump.h>
+#include <trace/hooks/traps.h>
+#include <trace/hooks/fault.h>
 
 /*
  * Export tracepoints that act as a bare tracehook (ie: have no trace event
@@ -99,3 +101,5 @@ EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_timer_calc_index);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_is_fpsimd_save);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_sched_show_task);
 EXPORT_TRACEPOINT_SYMBOL_GPL(android_vh_ftrace_format_check);
+EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_arm64_serror_panic);
+EXPORT_TRACEPOINT_SYMBOL_GPL(android_rvh_do_sea);
diff --git a/include/trace/hooks/fault.h b/include/trace/hooks/fault.h
new file mode 100644
index 000000000000..73f856de75e5
--- /dev/null
+++ b/include/trace/hooks/fault.h
@@ -0,0 +1,15 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#undef TRACE_SYSTEM
+#define TRACE_SYSTEM fault
+#define TRACE_INCLUDE_PATH trace/hooks
+#if !defined(_TRACE_HOOK_FAULT_H) || defined(TRACE_HEADER_MULTI_READ)
+#define _TRACE_HOOK_FAULT_H
+#include <linux/tracepoint.h>
+#include <trace/hooks/vendor_hooks.h>
+struct pt_regs;
+DECLARE_RESTRICTED_HOOK(android_rvh_do_sea,
+	TP_PROTO(unsigned long addr, unsigned long esr, struct pt_regs *regs),
+	TP_ARGS(addr, esr, regs), 1);
+#endif /* _TRACE_HOOK_FAULT_H */
+/* This part must be outside protection */
+#include <trace/define_trace.h>
diff --git a/include/trace/hooks/traps.h b/include/trace/hooks/traps.h
new file mode 100644
index 000000000000..f7e3443dc808
--- /dev/null
+++ b/include/trace/hooks/traps.h
@@ -0,0 +1,18 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#undef TRACE_SYSTEM
+#define TRACE_SYSTEM traps
+#define TRACE_INCLUDE_PATH trace/hooks
+
+#if !defined(_TRACE_HOOK_TRAPS_H) || defined(TRACE_HEADER_MULTI_READ)
+#define _TRACE_HOOK_TRAPS_H
+#include <linux/tracepoint.h>
+#include <trace/hooks/vendor_hooks.h>
+
+struct pt_regs;
+DECLARE_RESTRICTED_HOOK(android_rvh_arm64_serror_panic,
+	TP_PROTO(struct pt_regs *regs, unsigned long esr),
+	TP_ARGS(regs, esr), 1);
+
+#endif /* _TRACE_HOOK_TRAPS_H */
+/* This part must be outside protection */
+#include <trace/define_trace.h>
-- 
2.42.0

