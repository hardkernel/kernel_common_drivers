From dd5ea40a4c4fe56975cdc3ac00fab0bc0dfe82e0 Mon Sep 17 00:00:00 2001
From: Wanwei Jiang <wanwei.jiang@amlogic.com>
Date: Fri, 17 Mar 2023 17:35:31 +0800
Subject: [PATCH 2/2] bazel: support use bazel tool to build [1/1]

PD#SWPL-112151

Problem:
support use bazel tool to build

Solution:
support use bazel tool to build

Verify:
sc2

Change-Id: I96e80b97ed481f32239955748ffa52e7d40a85aa
Signed-off-by: Wanwei Jiang <wanwei.jiang@amlogic.com>
---
 BUILD.bazel | 9 ++++++++-
 modules.bzl | 5 +++++
 2 files changed, 13 insertions(+), 1 deletion(-)

diff --git a/BUILD.bazel b/BUILD.bazel
index 34d4b31f5854..eb1ccc0beddd 100644
--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -45,6 +45,13 @@ package(
     ],
 )
 
+load("//common_drivers:modules.bzl", "AMLOGIC_COMMON_PRIVATE_HEADERS")
+ddk_headers(
+    name = "amlogic_kernel_headers_unsafe",
+    hdrs = glob(AMLOGIC_COMMON_PRIVATE_HEADERS),
+    visibility = ["//visibility:public"],
+)
+
 _GKI_AARCH64_MAKE_GOALS = [
     "Image",
     "Image.lz4",
@@ -165,7 +172,7 @@ filegroup(
             "cscope.*",
             "ncscope.*",
         ],
-    ),
+    ) + ["//common_drivers:common_drivers_sources"],
     visibility = ["//visibility:public"],
 )
 
diff --git a/modules.bzl b/modules.bzl
index 49700e6cf657..226f1273559b 100644
--- a/modules.bzl
+++ b/modules.bzl
@@ -5,6 +5,7 @@
 This module contains a full list of kernel modules
  compiled by GKI.
 """
+load("//common_drivers:modules.bzl", "AMLOGIC_REMOVE_KERNEL_MODULES")
 
 # LINT.IfChange
 _COMMON_GKI_MODULES_LIST = [
@@ -143,6 +144,10 @@ def get_gki_modules_list(arch = None):
             arch,
         ))
 
+    remove_modules_items = {module: None for module in depset(AMLOGIC_REMOVE_KERNEL_MODULES).to_list()}
+    gki_modules_list = [module for module in depset(gki_modules_list).to_list() if module not in remove_modules_items] \
+			if remove_modules_items else gki_modules_list
+
     return gki_modules_list
 
 _KUNIT_FRAMEWORK_MODULES = [
-- 
