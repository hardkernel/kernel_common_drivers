From 39a8b4e7682ac84141fe8f3e9ce1caced12630ab Mon Sep 17 00:00:00 2001
From: Wanwei Jiang <wanwei.jiang@amlogic.com>
Date: Fri, 17 Mar 2023 17:35:31 +0800
Subject: [PATCH] bazel: support use bazel tool to build [1/1]

PD#SWPL-112151

Problem:
support use bazel tool to build

Solution:
support use bazel tool to build

Verify:
sc2

Change-Id: I96e80b97ed481f32239955748ffa52e7d40a85aa
Signed-off-by: Wanwei Jiang <wanwei.jiang@amlogic.com>
---
 BUILD.bazel     | 10 ++++++++++
 Kbuild          | 12 +++++++++---
 drivers/Kconfig |  8 ++++++++
 modules.bzl     |  6 ++++++
 4 files changed, 33 insertions(+), 3 deletions(-)

diff --git a/BUILD.bazel b/BUILD.bazel
index 86a2053888c7..6dd4fe7eae7d 100644
--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -45,6 +45,13 @@ package(
     ],
 )
 
+load("//common_drivers:modules.bzl", "AMLOGIC_COMMON_PRIVATE_HEADERS")
+ddk_headers(
+    name = "amlogic_kernel_headers_unsafe",
+    hdrs = glob(AMLOGIC_COMMON_PRIVATE_HEADERS),
+    visibility = ["//visibility:public"],
+)
+
 _GKI_AARCH64_MAKE_GOALS = [
     "Image",
     "Image.lz4",
@@ -3088,3 +3095,6 @@ pkg_zip(
 exports_files([
     "Makefile",
 ])
+
+load("//common:common_drivers/amlogic.bzl", "define_amlogic")
+define_amlogic()
diff --git a/Kbuild b/Kbuild
index bd26c93f68ef..88e1b7633843 100644
--- a/Kbuild
+++ b/Kbuild
@@ -97,6 +97,12 @@ obj-$(CONFIG_SAMPLES)	+= samples/
 obj-$(CONFIG_NET)	+= net/
 obj-y			+= virt/
 obj-y			+= $(ARCH_DRIVERS)
-obj-$(CONFIG_AMLOGIC_IN_KERNEL_MODULES)			+= $(COMMON_DRIVERS_DIR)/drivers/
-obj-$(CONFIG_AMLOGIC_IN_KERNEL_MODULES)			+= $(COMMON_DRIVERS_DIR)/sound/
-obj-$(CONFIG_AMLOGIC_IN_KERNEL_MODULES)			+= $(COMMON_DRIVERS_DIR)/samples/
+ifeq ($(CONFIG_AMLOGIC_IN_KERNEL_MODULES),y)
+ifeq ($(CONFIG_AMLOGIC_DDK_BUILD),y)
+	obj-y		+= $(COMMON_DRIVERS_DIR)/drivers/tty/serial/
+else
+	obj-y		+= $(COMMON_DRIVERS_DIR)/drivers/
+	obj-y		+= $(COMMON_DRIVERS_DIR)/sound/
+	obj-y		+= $(COMMON_DRIVERS_DIR)/samples/
+endif
+endif
diff --git a/drivers/Kconfig b/drivers/Kconfig
index 407bb559650a..1c0b99f9f56f 100644
--- a/drivers/Kconfig
+++ b/drivers/Kconfig
@@ -299,6 +299,14 @@ config AMLOGIC_KERNEL_VERSION
 	  so the default value is 15606
 	  the driver uses it to adapt different kernel versions
 
+config AMLOGIC_DDK_BUILD
+	bool "Amlogic ddk_module build"
+	default n
+	help
+	  this option is provide for control use ddk_module()
+	  to build common_drivers's drivers,
+	  if you don't enable this, it will use in-tree mode build.
+
 if AMLOGIC_IN_KERNEL_MODULES
 source "$(COMMON_DRIVERS_DIR)/drivers/Kconfig"
 source "$(COMMON_DRIVERS_DIR)/sound/Kconfig"
diff --git a/modules.bzl b/modules.bzl
index 5e613e7e78b2..97f044d1e434 100644
--- a/modules.bzl
+++ b/modules.bzl
@@ -6,6 +6,8 @@ This module contains a full list of kernel modules
  compiled by GKI.
 """
 
+load("//common:common_drivers/modules.bzl", "ALL_MODULES_REMOVE")
+
 _COMMON_GKI_MODULES_LIST = [
     # keep sorted
     "drivers/block/virtio_blk.ko",
@@ -138,6 +140,10 @@ def get_gki_modules_list(arch = None):
             arch,
         ))
 
+    remove_modules_items = {module: None for module in depset(ALL_MODULES_REMOVE).to_list()}
+    gki_modules_list = [module for module in depset(gki_modules_list).to_list() if module not in remove_modules_items] \
+			if remove_modules_items else gki_modules_list
+
     return gki_modules_list
 
 _KUNIT_FRAMEWORK_MODULES = [
-- 
2.42.0

