From 06ab147079e5b0c2fdc18085c8f694d2f8978aa8 Mon Sep 17 00:00:00 2001
From: Dezhen Wang <dezhen.wang@amlogic.com>
Date: Tue, 15 Oct 2024 11:30:12 +0000
Subject: [PATCH] scripts: separate the common_drivers dir from common dir
 [1/1]

PD#SWPL-188894

Problem:
after separating the common_drivers dir the common dir need to change
some file

Solution:
adjust the common file

Verify:
local

Change-Id: I8f062188569ac68d93e0ecb4b53a5cd5fc743d05
Signed-off-by: Dezhen Wang <dezhen.wang@amlogic.com>
---
 BUILD.bazel | 16 +++++++++++++---
 Makefile    |  6 +++++-
 modules.bzl |  2 +-
 3 files changed, 19 insertions(+), 5 deletions(-)

diff --git a/BUILD.bazel b/BUILD.bazel
index dc6263d9eeba..51170d0b562e 100644
--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -28,6 +28,7 @@ load(
 )
 load(":abi.bzl", "cc_binary_with_abi")
 load(":modules.bzl", "get_gki_modules_list", "get_kunit_modules_list")
+load("@bazel_skylib//rules:common_settings.bzl", "bool_flag")
 
 package(
     default_visibility = [
@@ -141,7 +142,7 @@ filegroup(
             "cscope.*",
             "ncscope.*",
         ],
-    ),
+    ) + ["//common_drivers:common_drivers_sources"],
     visibility = ["//visibility:public"],
 )
 
@@ -2683,5 +2684,14 @@ exports_files([
     "Makefile",
 ])
 
-load("//common:common_drivers/amlogic.bzl", "define_amlogic")
-define_amlogic()
+config_setting(
+    name = "common_drivers_on_top_dir",
+    flag_values = {":common_drivers_on_top": "True"},
+    visibility = ["//visibility:public"],
+)
+
+bool_flag(
+    name = "common_drivers_on_top",
+    build_setting_default = False,
+    visibility = ["//visibility:public"],
+)
diff --git a/Makefile b/Makefile
index 20f496da310a..bb22b6a7d1b1 100644
--- a/Makefile
+++ b/Makefile
@@ -431,7 +431,11 @@ endif
 # ifdef CONFIG_AMLOGIC_DRIVER
 # config cannot be used here to mark AMLOGIC modifications
 # If these three variables are not set externally, set their default values
-export COMMON_DRIVERS_DIR ?= common_drivers
+ifeq ($(shell test -d $(srctree)/common_drivers; echo $$?),0)
+	export COMMON_DRIVERS_DIR := common_drivers
+else
+	export COMMON_DRIVERS_DIR := ../common_drivers
+endif
 dtstree ?= $(COMMON_DRIVERS_DIR)/arch/$(SRCARCH)/boot/dts/amlogic
 export DTC_INCLUDE ?= $(srctree)/$(COMMON_DRIVERS_DIR)/include
 # endif
diff --git a/modules.bzl b/modules.bzl
index b4d89366bb11..44d4697eddba 100644
--- a/modules.bzl
+++ b/modules.bzl
@@ -6,7 +6,7 @@ This module contains a full list of kernel modules
  compiled by GKI.
 """
 
-load("//common:common_drivers/modules.bzl", "ALL_MODULES_REMOVE")
+load("//common_drivers:modules.bzl", "ALL_MODULES_REMOVE")
 
 _COMMON_GKI_MODULES_LIST = [
     # keep sorted
-- 
2.46.0

