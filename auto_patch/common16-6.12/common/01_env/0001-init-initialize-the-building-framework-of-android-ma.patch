 %.dtb: dtbs_prepare
+ifdef CONFIG_AMLOGIC_DRIVER
+	$(if $(wildcard $(srctree)/$(dtstree)/amlogic/$(addsuffix .dts,$(basename $@))),\
+		$(Q)$(MAKE) $(build)=$(dtstree) $(dtstree)/amlogic/$@,\
+		$(Q)$(MAKE) $(build)=$(dtstree) $(dtstree)/$@)
+else
 	$(Q)$(MAKE) $(build)=$(dtstree) $(dtstree)/$@
+endif
 
 %.dtbo: dtbs_prepare
+ifdef CONFIG_AMLOGIC_DRIVER
+	$(if $(wildcard $(srctree)/$(dtstree)/amlogic/$(addsuffix .dts,$(basename $@))),\
+		$(Q)$(MAKE) $(build)=$(dtstree) $(dtstree)/amlogic/$@,\
+		$(Q)$(MAKE) $(build)=$(dtstree) $(dtstree)/$@
+else
 	$(Q)$(MAKE) $(build)=$(dtstree) $(dtstree)/$@
+endif
 
 PHONY += dtbs dtbs_prepare dtbs_install dtbs_check
 dtbs: dtbs_prepare
