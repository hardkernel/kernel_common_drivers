+ifeq ($(CONFIG_AMLOGIC_IN_KERNEL_MODULES),y)
+ifeq ($(CONFIG_AMLOGIC_DDK_BUILD),y)
+	obj-y		+= $(COMMON_DRIVERS_DIR)/drivers/tty/serial/
+else
