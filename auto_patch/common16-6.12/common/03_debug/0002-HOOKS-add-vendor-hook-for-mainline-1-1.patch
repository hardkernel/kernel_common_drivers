 include/trace/hooks/dtask.h       | 21 +++++++++++++++++++++
 include/trace/hooks/ftrace_dump.h | 20 ++++++++++++++++++++
 include/trace/hooks/printk.h      |  0
 include/trace/hooks/sched.h       |  4 ++++
 kernel/printk/printk.c            |  0
 kernel/sched/core.c               |  2 ++
 kernel/sched/fair.c               | 11 +++++++++++
 kernel/sched/vendor_hooks.c       |  1 +
