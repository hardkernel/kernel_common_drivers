From ac2797ab7dcdd4346045068e189024dcdd6f85fa Mon Sep 17 00:00:00 2001
From: Shaleen Agrawal <shalagra@codeaurora.org>
Date: Wed, 13 Oct 2021 09:29:53 -0700
Subject: [PATCH] ANDROID: sched: Export set_next_entity

Export set_next_entity so that vendor modules can override the next task
selected by CFS.

Bug: 183674818
Change-Id: I118e5a9002ff5f80c1634d784424db74be13d831
Signed-off-by: Shaleen Agrawal <shalagra@codeaurora.org>
---
 kernel/sched/fair.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index d643faeb792f..9bd7f174831f 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -5598,7 +5598,7 @@ dequeue_entity(struct cfs_rq *cfs_rq, struct sched_entity *se, int flags)
 	return true;
 }

-static void set_next_entity(struct cfs_rq *cfs_rq, struct sched_entity *se)
+void set_next_entity(struct cfs_rq *cfs_rq, struct sched_entity *se)
 {
 	clear_buddies(cfs_rq, se);

@@ -5640,6 +5640,7 @@ static void set_next_entity(struct cfs_rq *cfs_rq, struct sched_entity *se)

 	se->prev_sum_exec_runtime = se->sum_exec_runtime;
 }
+EXPORT_SYMBOL_GPL(set_next_entity);

 static int dequeue_entities(struct rq *rq, struct sched_entity *se, int flags);

--
2.29.0

