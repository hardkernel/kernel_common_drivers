From b411d9f72dcd6b6c2ca0628bd15f46dbe1c2ddd4 Mon Sep 17 00:00:00 2001
From: Jianxiong Pan <jianxiong.pan@amlogic.com>
Date: Mon, 26 Feb 2024 17:23:16 +0800
Subject: [PATCH] crypto: add parameters to control zstd compress level [1/1]

PD#SWPL-158570

Problem:
ZSTD compress level is fixed

Solution:
add module parameters to control it. By default, set
compress level to 1

Verify:
txhd2.

Change-Id: I006a2857bc27e983ff12730e2962c80de3f098fb
Signed-off-by: Jianxiong Pan <jianxiong.pan@amlogic.com>
---
 crypto/zstd.c | 12 +++++++++++-
 1 file changed, 11 insertions(+), 1 deletion(-)

diff --git a/crypto/zstd.c b/crypto/zstd.c
index 154a969c83a8..997d2b006822 100644
--- a/crypto/zstd.c
+++ b/crypto/zstd.c
@@ -14,8 +14,11 @@
 #include <linux/zstd.h>
 #include <crypto/internal/scompress.h>
 
-
+#ifdef CONFIG_AMLOGIC_ZSTD
+static int zstd_def_level = 1;
+#else
 #define ZSTD_DEF_LEVEL	3
+#endif
 
 struct zstd_ctx {
 	zstd_cctx *cctx;
@@ -26,7 +29,11 @@ struct zstd_ctx {
 
 static zstd_parameters zstd_params(void)
 {
+#ifdef CONFIG_AMLOGIC_ZSTD
+	return zstd_get_params(zstd_def_level, 0);
+#else
 	return zstd_get_params(ZSTD_DEF_LEVEL, 0);
+#endif
 }
 
 static int zstd_comp_init(struct zstd_ctx *ctx)
@@ -252,6 +259,9 @@ static void __exit zstd_mod_fini(void)
 
 subsys_initcall(zstd_mod_init);
 module_exit(zstd_mod_fini);
+#ifdef CONFIG_AMLOGIC_ZSTD
+module_param_named(zstd_level, zstd_def_level, int, 0644);
+#endif
 
 MODULE_LICENSE("GPL");
 MODULE_DESCRIPTION("Zstd Compression Algorithm");
-- 
2.42.0

