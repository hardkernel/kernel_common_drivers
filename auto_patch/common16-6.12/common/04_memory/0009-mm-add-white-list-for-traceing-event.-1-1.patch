From 8d267c99434fd6a4f7d1ddebfc513f8bb8afbec1 Mon Sep 17 00:00:00 2001
From: "biao.sun" <biao.sun@amlogic.com>
Date: Thu, 2 Jan 2025 08:51:51 +0000
Subject: [PATCH] mm: autopatch: add black list for trace event [1/1]

PD#SWPL-192258

Problem:
There are too many trace event inodes

Solution:
add black list for trace event

Verify:
sc2

Change-Id: I0b50123e0d06ac0177eea3232556d34f9cff8f6d
Signed-off-by: biao.sun <biao.sun@amlogic.com>
---
 kernel/trace/trace_events.c | 80 +++++++++++++++++++++++++++++++++++++
 1 file changed, 80 insertions(+)

diff --git a/kernel/trace/trace_events.c b/kernel/trace/trace_events.c
index 7266ec2a4eea..c7dde4de8361 100644
--- a/kernel/trace/trace_events.c
+++ b/kernel/trace/trace_events.c
@@ -3219,6 +3219,78 @@ EXPORT_SYMBOL_GPL(trace_remove_event_call);

 #ifdef CONFIG_MODULES

+#ifdef CONFIG_AMLOGIC_MEMORY_OPT
+static char * const allow_trace[] = {
+	"sched",
+	"irq",
+	"freq",
+	"idle",
+	"block",
+	"binder",
+	"bpf_trace",
+	"cgroup",
+	"compaction",
+	"ext4",
+	"f2fs",
+	"ftrace",
+	"kmem",
+	"ion",
+	"mmap",
+	"power",
+	"rcu",
+	"task",
+	"events",
+	"signal",
+	"options",
+	"dmc_monitor",
+	"kprobes",
+	"vmscan",
+	"timer",
+	"workqueue",
+	"oom",
+	"ipi",
+	"preemptirq",
+	"clk",
+	"mmc",
+	"cpu_frequency",
+	"devfreq",
+	"per_cpu",
+	"thermal",
+	"filemap",
+};
+
+static int is_allowed_trace(const char *name)
+{
+	int i;
+
+	for (i = 0; i  < ARRAY_SIZE(allow_trace); i++) {
+		if (!strcmp(name, allow_trace[i]))
+			return 1;
+	}
+	return 0;
+}
+
+static int allow_trace_enable = 1;
+
+static int __init early_allow_trace_enable_param(char *buf)
+{
+	if (!buf)
+		return -EINVAL;
+
+	if (strcmp(buf, "off") == 0)
+		allow_trace_enable = 0;
+	else if (strcmp(buf, "on") == 0)
+		allow_trace_enable = 1;
+
+	pr_debug("allow_trace_enable %sabled\n", allow_trace_enable ? "en" : "dis");
+
+	return 0;
+}
+
+early_param("allow_trace_enable", early_allow_trace_enable_param);
+#endif
+
+
 static void trace_module_add_events(struct module *mod)
 {
 	struct trace_event_call **call, **start, **end;
@@ -3226,6 +3298,10 @@ static void trace_module_add_events(struct module *mod)
 	if (!mod->num_trace_events)
 		return;

+#ifdef CONFIG_AMLOGIC_MEMORY_OPT
+	if (allow_trace_enable && !is_allowed_trace(mod->name))
+		return;
+#endif
 	/* Don't add infrastructure for mods without tracepoints */
 	if (trace_module_has_bad_taint(mod)) {
 		pr_err("%s: module has bad taint, not creating trace events\n",
@@ -4046,6 +4122,10 @@ static __init int event_trace_enable(void)
 	for_each_event(iter, __start_ftrace_events, __stop_ftrace_events) {

 		call = *iter;
+#ifdef CONFIG_AMLOGIC_MEMORY_OPT
+		if (allow_trace_enable && !is_allowed_trace(call->class->system))
+			continue;
+#endif
 		ret = event_init(call);
 		if (!ret)
 			list_add(&call->list, &ftrace_events);
--
2.46.0

