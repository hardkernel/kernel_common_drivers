From 21e03093fb35e4b051ce4618dfcb7913650023f9 Mon Sep 17 00:00:00 2001
From: Jianxiong Pan <jianxiong.pan@amlogic.com>
Date: Thu, 21 Dec 2023 15:09:46 +0800
Subject: [PATCH] mm: add white list for trace event. [1/1]

PD#SWPL-150034

Problem:
There are too many trace event inodes

Solution:
Add white list for trace event, this can save about 10MB memory

Verify:
local.

Change-Id: I7f19805516e2d6f8c7e6ab4b3540336ff27e382a
Signed-off-by: Jianxiong Pan <jianxiong.pan@amlogic.com>
---
 fs/tracefs/inode.c          | 81 +++++++++++++++++++++++++++++++++++++
 kernel/trace/trace.c        |  2 +
 kernel/trace/trace_events.c |  8 ++++
 3 files changed, 91 insertions(+)

diff --git a/fs/tracefs/inode.c b/fs/tracefs/inode.c
index 99caf1c3d0c4..2b8c78b08bac 100644
--- a/fs/tracefs/inode.c
+++ b/fs/tracefs/inode.c
@@ -619,6 +619,77 @@ static struct dentry *__create_dir(const char *name, struct dentry *parent,
 	return tracefs_end_creating(dentry);
 }
 
+#ifdef CONFIG_AMLOGIC_MEMORY_OPT
+static char * const allow_trace[] = {
+	"sched",
+	"irq",
+	"freq",
+	"idle",
+	"block",
+	"binder",
+	"bpf_trace",
+	"cgroup",
+	"compaction",
+	"ext4",
+	"f2fs",
+	"ftrace",
+	"kmem",
+	"ion",
+	"mmap",
+	"power",
+	"rcu",
+	"task",
+	"events",
+	"signal",
+	"options",
+	"dmc_monitor",
+	"kprobes",
+	"vmscan",
+	"timer",
+	"workqueue",
+	"oom",
+	"ipi",
+	"preemptirq",
+	"clk",
+	"mmc",
+	"cpu_frequency",
+	"devfreq",
+	"per_cpu",
+	"thermal",
+	"filemap",
+};
+
+static int is_allowed_trace(const char *name)
+{
+	int i;
+
+	for (i = 0; i  < ARRAY_SIZE(allow_trace); i++) {
+		if (!strcmp(name, allow_trace[i]))
+			return 1;
+	}
+	return 0;
+}
+
+static int allow_trace_enable = 1;
+
+static int __init early_allow_trace_enable_param(char *buf)
+{
+	if (!buf)
+		return -EINVAL;
+
+	if (strcmp(buf, "off") == 0)
+		allow_trace_enable = 0;
+	else if (strcmp(buf, "on") == 0)
+		allow_trace_enable = 1;
+
+	pr_debug("allow_trace_enable %sabled\n", allow_trace_enable ? "en" : "dis");
+
+	return 0;
+}
+
+early_param("allow_trace_enable", early_allow_trace_enable_param);
+#endif
+
 /**
  * tracefs_create_dir - create a directory in the tracefs filesystem
  * @name: a pointer to a string containing the name of the directory to
@@ -641,6 +712,16 @@ struct dentry *tracefs_create_dir(const char *name, struct dentry *parent)
 	if (security_locked_down(LOCKDOWN_TRACEFS))
 		return NULL;
 
+#ifdef CONFIG_AMLOGIC_MEMORY_OPT
+	if (allow_trace_enable && !is_allowed_trace(name)) {
+		if (parent) {
+			if (!strcmp(parent->d_iname, "events"))
+				return NULL;
+			if (!is_allowed_trace(parent->d_iname))
+				return NULL;
+		}
+	}
+#endif
 	return __create_dir(name, parent, &tracefs_dir_inode_operations);
 }
 
diff --git a/kernel/trace/trace.c b/kernel/trace/trace.c
index c50a39fbeebe..7bbf8eeb4e92 100644
--- a/kernel/trace/trace.c
+++ b/kernel/trace/trace.c
@@ -8882,8 +8882,10 @@ static struct dentry *tracing_dentry_percpu(struct trace_array *tr, int cpu)
 
 	tr->percpu_dir = tracefs_create_dir("per_cpu", d_tracer);
 
+#ifndef CONFIG_AMLOGIC_MEMORY_OPT
 	MEM_FAIL(!tr->percpu_dir,
 		  "Could not create tracefs directory 'per_cpu/%d'\n", cpu);
+#endif
 
 	return tr->percpu_dir;
 }
diff --git a/kernel/trace/trace_events.c b/kernel/trace/trace_events.c
index 941a394d3911..87a26f3c108c 100644
--- a/kernel/trace/trace_events.c
+++ b/kernel/trace/trace_events.c
@@ -2375,7 +2375,9 @@ event_subsystem_dir(struct trace_array *tr, const char *name,
 
 	ei = eventfs_create_dir(name, parent, system_entries, nr_entries, dir);
 	if (IS_ERR(ei)) {
+	#ifndef CONFIG_AMLOGIC_MEMORY_OPT
 		pr_warn("Failed to create system directory %s\n", name);
+	#endif
 		__put_system(system);
 		goto out_free;
 	}
@@ -2584,7 +2586,9 @@ event_create_dir(struct eventfs_inode *parent, struct trace_event_file *file)
 	name = trace_event_name(call);
 	ei = eventfs_create_dir(name, e_events, event_entries, nr_entries, file);
 	if (IS_ERR(ei)) {
+	#ifndef CONFIG_AMLOGIC_MEMORY_OPT
 		pr_warn("Could not create tracefs '%s' directory\n", name);
+	#endif
 		return -1;
 	}
 
@@ -3212,9 +3216,11 @@ __trace_add_event_dirs(struct trace_array *tr)
 
 	list_for_each_entry(call, &ftrace_events, list) {
 		ret = __trace_add_new_event(call, tr);
+	#ifndef CONFIG_AMLOGIC_MEMORY_OPT
 		if (ret < 0)
 			pr_warn("Could not create directory for event %s\n",
 				trace_event_name(call));
+	#endif
 	}
 }
 
@@ -3678,9 +3684,11 @@ static void __trace_early_add_event_dirs(struct trace_array *tr)
 
 	list_for_each_entry(file, &tr->events, list) {
 		ret = event_create_dir(tr->event_dir, file);
+	#ifndef CONFIG_AMLOGIC_MEMORY_OPT
 		if (ret < 0)
 			pr_warn("Could not create directory for event %s\n",
 				trace_event_name(file->event_call));
+	#endif
 	}
 }
 
-- 
2.42.0

