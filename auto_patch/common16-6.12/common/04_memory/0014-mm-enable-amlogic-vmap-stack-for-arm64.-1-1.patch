+	#endif
 		el1_undef(regs, esr);
 		break;
 	case ESR_ELx_EC_BTI:
@@ -512,6 +521,9 @@ asmlinkage void noinstr el1h_64_sync_handler(struct pt_regs *regs)
 	case ESR_ELx_EC_SOFTSTP_CUR:
 	case ESR_ELx_EC_WATCHPT_CUR:
