--- a/arch/arm64/include/asm/stacktrace/common.h
+++ b/arch/arm64/include/asm/stacktrace/common.h
@@ -11,6 +11,10 @@
 
 #include <linux/types.h>
 
+#ifdef CONFIG_AMLOGIC_VMAP
