+#endif
+
 struct stack_info {
 	unsigned long low;
 	unsigned long high;
@@ -94,6 +98,14 @@ static inline int unwind_consume_stack(struct unwind_state *state,
 	if (stackinfo_on_stack(&state->stack, sp, size))
 		goto found;
 
+#ifdef CONFIG_AMLOGIC_VMAP
+	/*
+	 * keep search stack for task
+	 */
+	if (on_vmap_stack(sp, &state->stack))
+		goto found;
+#endif
+
 	next = unwind_find_next_stack(state, sp, size);
 	if (!next)
 		return -EINVAL;
diff --git a/arch/arm64/kernel/entry-common.c b/arch/arm64/kernel/entry-common.c
index 51384e16953e..c313ed13f8f1 100644
