		};

		opp10 {
			opp-hz = /bits/ 64 <1800000000>;
			opp-microvolt = <1009000>;
		};
	};

	meson_cpufreq {
		compatible = "amlogic, aml-cpufreq-v2";
		status = "okay";
		cluster0-cpu-supply = <&vddcpu0>;

		cluster0 {
			clocks = <&scmi_clk CLKID_SCMI_CPU_CLK>;
			clock-names = "cpuclk";
			voltage-tolerance = <0>;
			clock-latency = <50000>;
			//skip_volt_scaling;
			cluster_cores = <0 1 2 3>;
			//pdvfs_enabled;
		};
	};
};/* end of / */

&CPU0 {
	#cooling-cells = <2>;
	operating-points-v2 = <&opp_table0>,
			      <&opp_table1>,
			      <&opp_table2>,
			      <&opp_table3>;
};
