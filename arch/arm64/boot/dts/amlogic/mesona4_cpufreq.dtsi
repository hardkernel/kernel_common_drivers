	meson-cpufreq {
		compatible = "amlogic, aml-cpufreq";
		status = "okay";

		cluster0-cpu-supply = <&vddcpu0>;

		cluster0 {
			clocks = <&scmi_clk CLKID_CPU_CLK>;
			clock-names = "cpuclk";
			voltage-tolerance = <0>;
			clock-latency = <50000>;
			//skip_volt_scaling;
			cluster_cores = <0 1 2 3>;
			pdvfs_enabled;
			dsu-opp-table0 = <1000000 1200000 809000>,
					<1800000 1500000 869000>;
			dsu-opp-table1 = <1000000 1200000 809000>,
					<1800000 1500000 869000>;
			dsu-opp-table2 = <1000000 1200000 769000>,
					<1800000 1500000 829000>;
			dsu-opp-table3 = <1000000 1200000 729000>,
					<1800000 1500000 779000>;
		};
	};
};/* end of / */

&CPU0 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu_opp_table0>,
					<&cpu_opp_table1>,
					<&cpu_opp_table2>,
					<&cpu_opp_table3>;
};
