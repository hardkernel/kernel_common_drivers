		dsi_1 {
			model_name = "LX70WSK40164-V0";
			interface = "mipi";
			/*h_active, v_active, h_period, v_period, color_bit, width, height*/
			basic_setting = <600 1024 940 1058 8 90 153>;
			/*hs_width, hs_bp, hs_pol, vs_width, vs_bp, vs_pol*/
			lcd_timing = <60 140 0 4 14 0>;
			//<fr_adj_type clkss clk_auto_generate PixelClk>
			clk_attr = <2 0 1 60>;
			/* <lane, bit_rate, /, mode_init(0=video,1=cmd), mode_disp(0=video,1=cmd)*/
			/* video_mode(0=sync_pulse,1=sync_event,2=burst), clk_hs, />*/
			mipi_attr = <4 360 0 1 0 2 1 0>;
			/* dsi_init: data_type, num, data... */
			dsi_init_on = <
				0x39 4 0xB9 0xF1 0x12 0x87
				0x39 28 0xBA 0x33 0x81 0x05 0xF9 0x0E 0x0E 0x20 0x00 0x00 0x00 0x00
					0x00 0x00 0x00 0x44 0x25 0x00 0x91 0x0A 0x00 0x00 0x01 0x4F
					0x01 0x00 0x00 0x37
				0x39 4 0xB2 0x00 0x15 0x78
				0x39 11 0xB3 0x28 0x28 0x28 0x28 0x03 0xFF 0x00 0x00 0x00 0x00
				0x15 2 0xB4 0xA0
				0x39 3 0xB5 0x09 0x09
				0x39 3 0xB6 0x78 0x78
				0x39 3 0xB8 0x26 0x22
				0x15 2 0xBC 0x46
				0x39 6 0xBF 0x02 0x11 0x00 0x80 0x04
				0x39 10 0xC0 0x73 0x73 0x50 0x50 0x00 0x00 0x08 0x73 0x00
				0x39 18 0xC1 0x54 0x00 0x32 0x32 0x77 0xF1 0x3C 0x3C 0x7E 0x7E 0xCF
					0xCF 0x11 0x11 0x00 0x00 0x32
				0x39 13 0xC7 0xB8 0x00 0x0A 0x00 0x00 0x00 0x00 0x80 0xED 0xC7 0x00
					0xA5
				0x39 5 0xC8 0x10 0x40 0x1E 0x03
				0x39 2 0xCC 0x0B
				0x39 35 0xE0 0x00 0x02 0x03 0x23 0x38 0x3F 0x2D 0x27 0x04 0x08 0x0A
					0x0F 0x11 0x0E 0x11 0x12 0x18 0x00 0x02 0x03 0x23 0x38 0x3F
					0x2D 0x27 0x04 0x08 0x0A 0x0F 0x11 0x0E 0x11 0x12 0x18
				0x39 8 0xE1 0x11 0x11 0x91 0x00 0x00 0x00 0x00
				0x39 15 0xE3 0x07 0x07 0x0B 0x0B 0x03 0x0B 0x00 0x00 0x00 0x00 0xFF
					0x04 0xC0 0x10
				0x39 64 0xE9 0xC8 0x10 0x03 0x04 0x0A 0x80 0x81 0x12 0x31 0x23 0x4F
					0x81 0x80 0x81 0x37 0x08 0x00 0x04 0x08 0x00 0x00 0x00 0x00
					0x04 0x08 0x00 0x00 0x00 0x88 0x94 0xF8 0x13 0x57 0x18 0x88
					0x88 0x88 0x88 0x88 0x88 0x94 0xF8 0x02 0x46 0x08 0x88 0x88
					0x88 0x88 0x88 0x00 0x00 0x00 0x00 0x00 0x80 0x81 0x30 0x00
					0x00 0x00 0x00 0x00
				0x39 64 0xEA 0x01 0x10 0x01 0x02 0x03 0x00 0x00 0x00 0x00 0x00 0x00
					0x00 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88
					0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x88 0x23
					0x00 0x00 0x00 0xB8 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00
					0x00 0x00 0x00 0x04 0x0D 0x12 0x30 0x30 0x80 0x81 0x50 0x80
					0x81 0x00 0x00 0x00
				0x39 4 0xEF 0xFF 0xFF 0x01
				0x05 1 0x11
				0xfd 1 250
				0x05 1 0x29
				0xfd 1 50
				0xff 0>; /*ending*/
			dsi_init_off = <
				0x05 1 0x28
				0xfd 1 10 /*delay(ms)*/
				0x05 1 0x10
				0xfd 1 10 /*delay(ms)*/
				0xff 0>; /*ending*/
			extern_init = <0xff>; /*0xff for invalid*/

			/* power step: type, index, value, delay(ms) */
			power_on_step = <
				0 0 1 10 /* LCD_VCC */
				0 2 1 0  /* BL_EN, IO_VDD */
				0 1 0 10
				0 1 1 15 /* LCD_RST */
				2 0 0 0
				0 3 1 0 /* BL_PWM */
				0xff 0 0 0>; /*ending*/
			power_off_step = <
				0 3 0 40
				2 0 0 50
				0 2 0 5
				0 1 0 5
				0 0 0 0
				0xff 0 0 0>; /*ending*/
			backlight_index = <0xff>;
		};
		dsi_test {
			model_name = "DSI_test";
			interface = "mipi";
			basic_setting = <1920 1080 2200 1125 8 160 90>;
			lcd_timing = <44 148 0 5 36 0>;
			clk_attr = <0 0 1 165>;
			mipi_attr = <4 2500 0 1 0 0 1 0>;
			/* dsi_init: data_type, num, data... */
			dsi_init_on = <0xff 0xff>; /* ending flag */
			dsi_init_off = <0xff 0xff>; /* ending flag */
			/* extern_init: 0xff for invalid */
			extern_init = <0xff>;
			/* power step: type,index,value,delay(ms) */
			power_on_step = <
				2 0 0 0
				0xff 0 0 0>;
			power_off_step = <
				2 0 0 0
				0xff 0 0 0>;
			backlight_index = <0xff>;
		};

		dsi_detect{
			model_name = "dsi_panel_detect";
			interface = "mipi";

			//<H_active, V_active, H_period, V_period, lcd_bits, width, height>
			basic_setting = <640 480 800 525 8 40 30>;
			//<HSync, HS_backporch, HS_pol, VSync, VS_backporch, VS_pol>
			lcd_timing = <96 40 0 2 25 0>;
			//<fr_adj_type clk_ss clk_auto_generate PixelClk>
			clk_attr = <0xff 0 1 25175000>;
			//<lane_num bit_rate \ mode_init mode_display video_mode clk_always_hs \>
			mipi_attr = <4 200 0 1 0 2 1 0>;

			//<stored2env \ \ \>
			dsi_detect_attr = <1 0 0 0>;
			/* dsi_init: data_type, num, data... */
			det0_init_table = <
				0x39 4 0xff 0x98 0x81 0x01
				0x06 1 0x00 0x06 1 0x01 0x06 1 0x02
				0xff 0>;
			det0_match_seq = <3 0x98 0x81 0x5c>;
			det0_type = "mipi_2";

			det1_match_seq = <8 0xff 0xff 0xff 0xff 0xff 0xff 0xff 0xff>;
			det1_type = "mipi_1";

			fallback_type = "mipi_0";

			/* power step: type, index, value, delay(ms) */
			power_on_step = <
				0 0 1 10 /*vcc en*/
				0 1 1 1 /*rst high*/
				0 3 1 30 /*3v3 high*/
				0 1 0 10 /*rst low*/
				0 1 1 20 /*rst high*/
				2 0 0 0
				0 0 0 1
				0 1 0 1 /*rst low*/
				0 3 0 1 /*3v3 low*/
				0xff 0 0 0>; /*ending*/
			power_off_step = <0xff 0 0 0>; /*ending*/
			backlight_index = <0xff>;
		};

		ports {
			port {
				#address-cells = <1>;
				#size-cells = <0>;
				lcd0_to_drm: endpoint@0 {
					reg = <0>;
					remote-endpoint = <0>;
				};
			};
		};
	};
	lcd_extern{
		compatible = "amlogic, lcd_extern";
		status = "disabled";
		index = <0>;
		key_valid = <0>;
		i2c_bus = "i2c_bus_a";
	};

	backlight{
		compatible = "amlogic, backlight-s6";
		status = "disabled";
		index = <0>;
		key_valid = <0>;
		pinctrl-names = "pwm_on","pwm_off";
		//pinctrl-0 = <&pwm_e_pins1>; /* GPIOF_4*/
		//pinctrl-1 = <&bl_pwm_off_pins>; /* GPIOY_1*/
		pinctrl_version = <2>; /* for uboot */
		interrupts = <0 197 1>, <0 194 1>;
		interrupt-names = "vsync","vsync2";
		bl_pwm_config = <&bl_pwm_conf>;

		/* pwm port: PWM_A, PWM_B, PWM_C, PWM_D, PWM_E, PWM_F, PWM_VS*/
		/* power index:(point gpios_index, 0xff=invalid) */
		/* power value:(0=output low, 1=output high, 2=input) */
		/* power delay:(unit in ms) */
		bl-gpios = <&gpio GPIOA_5  GPIO_ACTIVE_HIGH>, //LCD_BL_EN_I2S_DOUT_7
			   <&gpio GPIOA_11 GPIO_ACTIVE_HIGH>, //LCD_BL_PWM_LINE_IN_DETECT
			   <&gpio GPIOF_4 GPIO_ACTIVE_HIGH>; //LCD_BL_PWM_TEST_ON_sta_LED
		bl_gpio_names = "GPIOA_5", "GPIOA_11", "GPIOF_4";

		backlight_0{
			index = <0>;
			bl_name = "backlight_pwm";
			bl_level_default_uboot_kernel = <255 255>;
			bl_level_attr = <255 10 /*max, min*/
				128 128>; /*mid, mid_mapping*/
			bl_ctrl_method = <1>; /*1=pwm,2=pwm_combo,3=ldim*/
			bl_power_attr = <0 /*en_gpio_index*/
				1 0 /*on_value, off_value*/
				200 200>; /*on_delay(ms), off_delay(ms)*/
			bl_pwm_port = "PWM_C";
			bl_pwm_attr = <1 /*pwm_method(0=negative, 1=positive)*/
				2000 /*pwm_freq(pwm:Hz, pwm_vs:multiple of vs)*/
				100 5>; /*duty_max(%), duty_min(%)*/
			bl_pwm_power = <2 0 /*pwm_gpio_index, pwm_gpio_off*/
				10 10>; /*pwm_on_delay(ms), pwm_off_delay(ms)*/
			en_sequence_reverse = <0>; /* 1 for reverse */
		};
	};

	bl_pwm_conf:bl_pwm_conf{
		pwm_channel_0 {
			pwm_port = "PWM_C";
			pwms = <&pwm_c MESON_PWM_0 30040 0>;
		};
	};

}; /* end of / */

