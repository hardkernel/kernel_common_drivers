	meson_cooldev: meson-cooldev@0 {
		status = "okay";
		compatible = "amlogic, meson-cooldev";
		cooling_devices {
			gpufreq_cool {
				dyn_coeff = <358>;
				node_name = "bifrost";
				device_type = "gpufreq";
			};
		};
	};/*meson cooling devices end*/

	thermal_zones: thermal-zones {
		soc_thermal: soc_thermal {
			polling-delay = <1000>;
			polling-delay-passive = <100>;
			sustainable-power = <1398>;
			thermal-sensors = <&cpu_tsensor 0>;
			trips {
				cpu_switch_on: trip-point@0 {
					temperature = <95000>;
					hysteresis = <5000>;
					type = "passive";
				};
				cpu_control: trip-point@1 {
					temperature = <105000>;
					hysteresis = <5000>;
					type = "passive";
				};
				cpu_critical: trip-point@2 {
					temperature = <115000>;
					hysteresis = <1000>;
					type = "critical";
				};
			};
			cooling-maps {
				cpufreq_cooling_map {
					trip = <&cpu_control>;
					cooling-device = <&CPU0 0 7>;
					contribution = <1024>;
				};
				gpufreq_cooling_map {
					trip = <&cpu_control>;
					cooling-device = <&gpu 0 3>;
					contribution = <1024>;
				};
			};
		};

		top_thermal: top_thermal {
			polling-delay = <2000>;
			polling-delay-passive = <1000>;
			sustainable-power = <1398>;
			thermal-sensors = <&top_tsensor 1>;
			trips {
				top_switch_on: trip-point@0 {
					temperature = <95000>;
					hysteresis = <5000>;
					type = "passive";
				};
				top_control: trip-point@1 {
					temperature = <105000>;
					hysteresis = <5000>;
					type = "passive";
				};
				top_critical: trip-point@2 {
					temperature = <115000>;
					hysteresis = <1000>;
					type = "critical";
				};
			};
		};

		vir_thermal: vir_thermal {
			polling-delay = <1000>;
			polling-delay-passive = <100>;
			thermal-sensors = <&vir_tsensor 0>;
			trips {
				vir_control: trip-point@0 {
					temperature = <105000>;
					hysteresis = <3000>;
					type = "passive";
				};
			};
			cooling-maps {
				dpss_cooling_map {
					trip = <&vir_control>;
					cooling-device = <&dpss_process 0 1>;
				};
			};
		};
	};/*thermal zone end*/

	ddr_control: ddr_control {
		compatible = "amlogic, ddr-control";
		reg = <0 0xfe340894 0 0x4>,
		      <0 0xfe340814 0 0x4>,
		      <0 0xfe3408a8 0 0x4>;
		reg-names = "sip-addr",
			    "type-addr",
			    "freq-addr";
		sip-mask = <24 8>;
		type-mask = <8 8>;
		freq-mask = <0 16>;
		status = "okay";
		ddr3_nosip {
			particle = <DDR3_NOSIP_PARTICLE>;
			particle-flag = <DDR_SIP_TYPE_FLAG>;
			condition-type = <DDR_THERMAL>;
			zone-name = "soc_thermal";
			caddr = <0xfe3404b4>,
				<0xfe3405b4>,
				<0xfe3004b4>,
				<0xfe3005b4>;
			caddr-mask = <0 16 0 16>,
				     <0 16 0 16>;
			cstep-val = <85000 90000 95000 100000>,
				    <105000 110000 115000 120000>;
			caddr-val = <7800 3900 7800 3900>,
				    <6240 3120 6240 3120>,
				    <4875 2438 4875 2438>,
				    <4875 2438 4875 2438>,
				    <3900 1950 3900 1950>,
				    <3120 1560 3120 1560>,
				    <2437 1219 2437 1219>,
				    <1950 975  1950 975>;
		};
		ddr3_sip {
			particle = <DDR3_SIP_PARTICLE>;
			particle-flag = <DDR_SIP_TYPE_FLAG>;
			condition-type = <DDR_THERMAL>;
			zone-name = "soc_thermal";
			caddr = <0xfe3404b4>,
				<0xfe3405b4>,
				<0xfe3004b4>,
				<0xfe3005b4>;
			caddr-mask = <0 16 0 16>,
				     <0 16 0 16>;
			cstep-val = <85000 90000 95000 100000>,
				    <105000 110000 115000 120000>;
			caddr-val = <7800 3900 7800 3900>,
				    <6240 3120 6240 3120>,
				    <4875 2438 4875 2438>,
				    <4875 2438 4875 2438>,
				    <3900 1950 3900 1950>,
				    <3120 1560 3120 1560>,
				    <2437 1219 2437 1219>,
				    <1950 975  1950 975>;
		};
		ddr4_nosip {
			particle = <DDR4_NOSIP_PARTICLE>;
			particle-flag = <DDR_SIP_TYPE_FLAG>;
			condition-type = <DDR_THERMAL>;
			zone-name = "soc_thermal";
			caddr = <0xfe3404b4>,
				<0xfe3405b4>,
				<0xfe3004b4>,
				<0xfe3005b4>;
			caddr-mask = <0 16 0 16>,
				     <0 16 0 16>;
			cstep-val = <85000 90000 95000 100000>,
				    <105000 110000 115000 120000>;
			caddr-val = <7800 3900 7800 3900>,
				    <6240 3120 6240 3120>,
				    <4875 2438 4875 2438>,
				    <4875 2438 4875 2438>,
				    <3900 1950 3900 1950>,
				    <3120 1560 3120 1560>,
				    <2437 1219 2437 1219>,
				    <1950 975  1950 975>;
		};
		ddr4_sip {
			particle = <DDR4_SIP_PARTICLE>;
			particle-flag = <DDR_SIP_TYPE_FLAG>;
			condition-type = <DDR_THERMAL>;
			zone-name = "soc_thermal";
			caddr = <0xfe3404b4>,
				<0xfe3405b4>,
				<0xfe3004b4>,
				<0xfe3005b4>;
			caddr-mask = <0 16 0 16>,
				     <0 16 0 16>;
			cstep-val = <85000 90000 95000 100000>,
				    <105000 110000 115000 120000>;
			caddr-val = <7800 3900 7800 3900>,
				    <6240 3120 6240 3120>,
				    <4875 2438 4875 2438>,
				    <4875 2438 4875 2438>,
				    <3900 1950 3900 1950>,
				    <3120 1560 3120 1560>,
				    <2437 1219 2437 1219>,
				    <1950 975  1950 975>;
		};
	};

	crg_drd_glue: crgdrdglue@fe350000{
		compatible = "amlogic, crg-drd-glue";
		status = "disabled";
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;
		reg = <0x0 0xfe010330 0x0 0x4>;/* trim_reg */
		def-drd-controller = <1>;

		usbphya: usbphya@fe358000 {
			compatible = "amlogic,uphy-t6x";
			status = "disabled";
			#address-cells = <1>;
			#size-cells = <1>;
			//ranges = <0 0 0 0x1000>;
			index = <0>;
			reg = <0x0 0xfe358000 0x0 0x0>;
			u2paport0: u2p@0 {
				#phy-cells = <0>;
				port-speed = <0x0>; /* 0~2: HS HSP SS */
				reg = <0xfe358000 0x100
						0xfe002000 0x100
						0xfe010330 0x4
						0xfe35c000 0x60>;
				reset-level = <0x40>;
				phy-reset-level-bits = <6>;
				usb-comb-reset-bit = <0>;
				usb-apb-reset-bit = <49>;
				usb-reset-bit = <1>;
				pll-settings = <0x0
								0x0
								0x0
								0x0
								0x7>;
				/* misnamed, is CLKID_SYS_USB_U3DRD */
				clocks = <&clkc CLKID_SYS_USB_U2H>,
							<&clkc CLKID_USB3_250M>;
				clock-names = "crg_general",
							"usb_clk_250m";
				interrupts = <GIC_SPI 130 IRQ_TYPE_EDGE_RISING>;
				u3-companinon;
			};

			u3paport0: u3p@80 {
				#phy-cells = <0>;
				port-speed = <0x3>; /* 0~2: HS HSP SS */
				reg = <0xfe358100 0x20		/* phy3 cfg base */
						0xfe002000 0x100	/* reset base */
						0xfe35a000 0x184	/* phy3 ctrl base */
						0xfe01034c 0x4>;	/* phy3 trim base */
				usb3-phy-reset-bit = /bits/ 8 <9>;
				usb3-apb-reset-bit = /bits/ 8 <9>;
				usb3-controller-reset-bit = /bits/ 8 <1>;
				reset-level-shift = <0x40>;
				apb-reset-offset = <0x4>;
				clocks = <&clkc CLKID_SYS_USB_U2H>,
							<&clkc CLKID_USB3_250M>;
				clock-names = "u3p_clk_0",
								"u3p_clk_1";
				pll-sw-cfg;
			};
		};

		crg_drd_a: crgdrd20@fe350000 {
			status = "disabled";
			reg = <0x0 0xfe350000 0x0 0x8000>;
			interrupts = <GIC_SPI 131 IRQ_TYPE_EDGE_RISING>;
			phys = <&u2paport0>, <&u3paport0>;
			phy-names = "usb2-phy", "usb3-phy";
			clocks = <&clkc CLKID_SYS_USB_U2H>;
			clock-names = "crg_general";
			resets = <&reset RESET_USB0>;
			reset-names = "udrd";
			rd-outstanding-tune = <0x8>;
			in-nak-rty = <0x5>;
			index = <0>;
		};

		crg_udc_a: crgudc20@fe350000 {
			status = "disabled";
			controller-type = <1>; /* 1: aml phy 4: m31 phy */
			reg = <0x0 0xfe350000 0x0 0x8000>;
			interrupts = <GIC_SPI 131 IRQ_TYPE_EDGE_RISING>;
			port-speed = <3>; /* 0~3: unknown, low, full, high */
			phys = <&u2paport0>;
			clocks = <&clkc CLKID_SYS_USB_U2H>;
			clock-names = "usb_general";
			resets = <&reset RESET_USB0>;
			reset-names = "udrd";
			version = <1>; /* forbid vbus detect */
			suspend-scheme = <0x0>;
			index = <0>;
		};

		usbphyb: usbphyb@fe368000 {
			compatible = "amlogic,uphy-t6x";
			status = "disabled";
			#address-cells = <1>;
			#size-cells = <1>;
			//ranges = <0 0 0 0x1000>;
			index = <1>;
			reg = <0x0 0xfe368000 0x0 0x0>;
			u2pbport0: u2p@0 {
				#phy-cells = <0>;
				port-speed = <0x0>; /* 0~2: HS HSP SS */
				reg = <0xfe368000 0x100
						0xfe002000 0x100
						0xfe010330 0x4
						0xfe36c000 0x60>;
				reset-level = <0x40>;
				phy-reset-level-bits = <7>;
				usb-comb-reset-bit = <2>;
				usb-apb-reset-bit = <50>;
				usb-reset-bit = <3>;
				pll-settings = <0x0
								0x0
								0x0
								0x0
								0x7>;
				clocks = <&clkc CLKID_SYS_USB_U2DRD>;
				clock-names = "crg_general";
				interrupts = <GIC_SPI 78 IRQ_TYPE_EDGE_RISING>;
			};
		};

		crg_drd_b: crgdrd21@fe360000 {
			status = "disabled";
			reg = <0x0 0xfe360000 0x0 0x8000>;
			interrupts = <GIC_SPI 79 IRQ_TYPE_EDGE_RISING>;
			phys = <&u2pbport0>;
			phy-names = "usb2-phy";
			clocks = <&clkc CLKID_SYS_USB_U2DRD>;
			clock-names = "crg_general";
			resets = <&reset RESET_USB1>;
			reset-names = "udrd";
			rd-outstanding-tune = <0x8>;
			in-nak-rty = <0x5>;
			index = <1>;
		};

		crg_udc_b: crgudc21@fe360000 {
			status = "disabled";
			controller-type = <1>; /* 1: aml phy 4: m31 phy */
			reg = <0x0 0xfe360000 0x0 0x8000>;
			interrupts = <GIC_SPI 79 IRQ_TYPE_EDGE_RISING>;
			port-speed = <3>; /* 0~3: unknown, low, full, high */
			phys = <&u2pbport0>;
			clocks = <&clkc CLKID_SYS_USB_U2DRD>;
			clock-names = "usb_general";
			resets = <&reset RESET_USB1>;
			reset-names = "udrd";
			version = <1>; /* forbid vbus detect */
			suspend-scheme = <0x0>;
			index = <1>;
		};
	};

	usbphyc: usbphyc@fe378000 {
		compatible = "amlogic,uphy-t6x";
		status = "disabled";
		#address-cells = <1>;
		#size-cells = <1>;
		//ranges = <0 0 0 0x1000>;
		reg = <0x0 0xfe378000 0x0 0x0>;
		u2pcport0: u2p@0 {
			#phy-cells = <0>;
			port-speed = <0x0>; /* 0~2: HS HSP SS */
			reg = <0xfe378000 0x100
					0xfe002000 0x100
					0xfe010330 0x4
					0xfe37c000 0x60>;
			reset-level = <0x40>;
			phy-reset-level-bits = <8>;
			usb-comb-reset-bit = <4>;
			usb-apb-reset-bit = <62>;
			usb-reset-bit = <5>;
			pll-settings = <0x0
							0x0
							0x0
							0x0
							0x7>;
			clocks = <&clkc CLKID_SYS_USB_U22H>,
						<&clkc CLKID_USB2_48M_PRE>,
						<&clkc CLKID_USB2_48M_CLK>;
			clock-names = "crg_general",
						"clk_soc_u2drd_48m_pre",
						"clk_soc_u2drd_48m";
			/* 48m usb2_48m_clk_pre cfg. */
			assigned-clocks = <&clkc CLKID_USB2_48M_CLK>, <&clkc CLKID_USB2_48M_PRE>;
			assigned-clock-parents = <&clkc CLKID_USB2_48M_PRE>, <0>;
			assigned-clock-rates = <0>, <48000000>;
			/* 48m usb2_48m_clk_tmp cfg not used. */
			sw-hsp;
		};
	};

	crg_host_c: crghostc@fe370000 {
		compatible = "amlogic, crg-host-drd";
		status = "disabled";
		reg = <0x0 0xfe370000 0x0 0x8000>;
		interrupts = <GIC_SPI 55 IRQ_TYPE_EDGE_RISING>;
		phys = <&u2pcport0>;
		phy-names = "usb2-phy";
		clocks = <&clkc CLKID_SYS_USB_U22H>;
		clock-names = "crg_general";
		resets = <&reset RESET_USB2>;
		reset-names = "udrd";
		rd-outstanding-tune = <0x8>;
		in-nak-rty = <0x5>;
	};

	cpu_info {
		compatible = "amlogic, cpuinfo";
		cpuinfo_cmd = <0x82000044>;
	};

	lut_dma:lut_dma {
		compatible = "amlogic, meson-s5, lut_dma";
		status = "okay";
	};

	efusecheck: efusecheck{
		maincmd = <0x8200003E>;
		checknum = <3>;
		check0 = <&check_0>;
		check1 = <&check_1>;
		check2 = <&check_2>;
		check_0:check_0{
			checkname = "dgpk1";
			subcmd = <0x1000>;
		};
		check_1:check_1{
			checkname = "dgpk2";
			subcmd = <0x1001>;
		};
		check_2:check_2{
			checkname = "aud_id";
			subcmd = <0x1002>;
		};
	};

	efuse: efuse{
		compatible = "amlogic, efuse";
		reg = <0x0 0xfe440040 0x0 0x4>;
		secureboot_mask = <0x00000c00>;
		read_cmd = <0x82000030>;
		write_cmd = <0x82000031>;
		get_max_cmd = <0x82000033>;
		mem_in_base_cmd = <0x82000020>;
		mem_out_base_cmd = <0x82000021>;
		efuse_pattern_size = <0x600>;
		efuse_obj_cmd_status = <0x1>;
		efuse_cali_item_read = <0x1>;
		key = <&efusekey>;
		check = <&efusecheck>;
		clock-names = "efuse_clk";
		status = "okay";
	};

	efusekey:efusekey{
		keynum = <4>;
		key0 = <&key_0>;
		key1 = <&key_1>;
		key2 = <&key_2>;
		key3 = <&key_3>;
		key_0:key_0{
			keyname = "mac";
			offset = <0>;
			size = <6>;
		};
		key_1:key_1{
			keyname = "mac_bt";
			offset = <6>;
			size = <6>;
		};
		key_2:key_2{
			keyname = "mac_wifi";
			offset = <12>;
			size = <6>;
		};
		key_3:key_3{
			keyname = "usid";
			offset = <18>;
			size = <16>;
		};
	};

	state_led: state_led {
		compatible = "amlogic,state-led-aocpu";
		mboxes = <&mbox_fifo T6X_REE2AO_LED>;
		status = "disabled";
	};

	chosen {
		bootargs = "usbcore.autosuspend=-1 dm_mod.reserved_bio_based_ios=8";
	};

	aml_mkl {
		compatible = "amlogic,aml_mkl";
		reg = <0x0 0xfe440200 0x0 0xf0>;
		kl_type = <1>;
		kl_vid_type = <1>;
		kl_offset = <0x80 0x88 0x8c 0x90>;
		status = "okay";
	};

	aml_kt {
		compatible = "amlogic,aml_kt";
		reg = <0x0 0xfe440500 0x0 0xa0>;
		kt_offset = <0x80 0x88 0x8c 0x90 0x94 0x98 0x9c>;
		kt_cap = <0x2407 0x63f 0 16 0 32>;
		kt_reserved = <0>;
		kt_host_key_max_len = <32>;
		status = "okay";
	};

	codec_mm {
		compatible = "amlogic, codec, mm";
		memory-region = <&codec_mm_cma &secure_vdec_reserved>;
		dev_name = "codec_mm";
		status = "okay";
		/*
		 * scatter_alloc_mode: the mode of scatter memory allocation
		 * 0: default mode, alloc from system and cma
		 * 1: only alloc from system
		 */
		scatter_alloc_mode = <1>;
		/* secure memory controller para <switch  align_2n> */
		secure_ctrl_para = <1 16>;
	};

	tvafe_avin_detect {
		compatible = "amlogic, t6x_tvafe_avin_detect";
		status = "okay";
		device_mask = <1>;/*bit0:ch1;bit1:ch2*/
		reg = <0x0 0xfe00a000 0x0 0x400>; /* cvbs irq base */
		interrupts = <0 173 1>,
					<0 172 1>;
	};

	tvafe {
		compatible = "amlogic, tvafe-t6x";
		/*memory-region = <&tvafe_cma_reserved>;*/
		status = "okay";
		flag_cma = <1>;/*1:share with codec_mm;0:cma alone*/
		cma_size = <5>;/*MByte*/
		reg = <0x0 0xfe072000 0x0 0x2000/*tvafe reg base*/
			0x0 0xfe008000 0x0 0x2000>; /*ana reg base*/
		reserve-iomap = "true";
		tvafe_id = <0>;
		//pinctrl-names = "default";
		/*!!particular sequence, no more and no less!!!*/
		tvafe_pin_mux = <
				3 /* TVAFE_CVBS_IN2, CVBS_IN0 = 0 */
				1 /* TVAFE_CVBS_IN0, CVBS_IN1 */
				2 /* TVAFE_CVBS_IN1, CVBS_IN2 */
				4 /* TVAFE_CVBS_IN3, CVBS_IN3 */
		>;
		clocks = <&clkc CLKID_CDAC_CLK>;
		clock-names = "vdac_clk_gate";
		cutwindow_val_h = <0 0 0 0 8>; /* level 0~4 */
		cutwindow_val_v = <4 8 14 16 24>;  /* level 0~4 */
		horizontal_dir0 = <148 148 148 148 148>;
		horizontal_dir1 = <148 168 166 160 148>;
		horizontal_stp0 = <0 0 0 0 0>;
		horizontal_stp1 = <0 0 0 0 0>;
		macrovision = <1>;
	};

	vbi {
		compatible = "amlogic, vbi";
		status = "okay";
		interrupts = <0 210 1>;
	};

	unifykey {
		compatible = "amlogic,unifykey";
		status = "okay";

		unifykey-num = <15>;
		unifykey-index-0 = <&keysn_0>;
		unifykey-index-1 = <&keysn_1>;
		unifykey-index-2 = <&keysn_2>;
		unifykey-index-3 = <&keysn_3>;
		unifykey-index-4 = <&keysn_4>;
		unifykey-index-5 = <&keysn_5>;
		unifykey-index-6 = <&keysn_6>;
		unifykey-index-7 = <&keysn_7>;
		unifykey-index-8 = <&keysn_8>;
		unifykey-index-9 = <&keysn_9>;
		unifykey-index-10 = <&keysn_10>;
		unifykey-index-11 = <&keysn_11>;
		unifykey-index-12 = <&keysn_12>;
		unifykey-index-13 = <&keysn_13>;
		unifykey-index-14 = <&keysn_14>;

		keysn_0: key_0{
			key-name = "usid";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_1:key_1{
			key-name = "mac";
			key-device  = "normal";
			key-permit = "read","write","del";
		};
		keysn_2:key_2{
			key-name = "secure_boot_set";
			key-device = "efuse";
			key-permit = "write";
		};
		keysn_3:key_3{
			key-name = "mac_bt";
			key-device = "normal";
			key-permit = "read","write","del";
			key-type  = "mac";
		};
		keysn_4:key_4{
			key-name = "mac_wifi";
			key-device = "normal";
			key-permit = "read","write","del";
			key-type  = "mac";
		};
		keysn_5:key_5{
			key-name = "hdcp2_rx";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_6:key_6{
			key-name = "deviceid";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_7:key_7{
			key-name = "lcd";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_8:key_8{
			key-name = "lcd_extern";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_9:key_9{
			key-name = "backlight";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_10:key_10{
			key-name = "lcd_tcon";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_11:key_11{
			key-name = "lcd_tcon_spi";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_12:key_12{
			key-name = "oemkey";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_13:key_13{
			key-name = "model_name";
			key-device = "normal";
			key-permit = "read","write","del";
		};
		keysn_14:key_14{
			key-name = "diag_state";
			key-device = "normal";
			key-permit = "read","write","del";
		};
	}; /* End unifykey */

	hdmirx: hdmirx {
		compatible = "amlogic, hdmirx_t6x";
		#address-cells=<2>;
		#size-cells=<2>;
		/*memory-region = <&hdmirx_emp_cma_reserved>;*/
		status = "okay";
		pinctrl-names = "hdmirx_pins";
		pinctrl-0 = <&hdmirx_a_mux &hdmirx_b_mux
			&hdmirx_c_mux &hdmirx_d_mux>;
		repeat = <0>;
		/*power-domains = <&pwrdm PDIP_T6D_VPU_HDMI>;*/
		interrupts = <0 283 IRQ_TYPE_LEVEL_HIGH
		0 284 IRQ_TYPE_LEVEL_HIGH
		0 285 IRQ_TYPE_LEVEL_HIGH
		0 286 IRQ_TYPE_LEVEL_HIGH>;
		clocks =<&clkc CLKID_HDMIRX_CFG>,
			<&clkc CLKID_HDMIRX_ACR>,
			<&clkc CLKID_HDMIRX_METER>,
			<&clkc CLKID_HDMIRX_2M>,
			<&clkc CLKID_HDMIRX_5M>,
			<&clkc CLKID_HDMIRX_HDCP>,
			<&xtal>,
			<&clkc CLKID_FCLK_DIV4>,
			<&clkc CLKID_FCLK_DIV5>;
		clock-names = "hdmirx_cfg_clk",
				"cts_hdmirx_acr_ref_clk",
				"cts_hdmirx_meter_clk",
				"cts_hdmirx_2m_clk",
				"cts_hdmirx_5m_clk",
				"cts_hdmirx_hdcp2x_eclk",
				"xtal",
				"fclk_div4",
				"fclk_div5";
		//power-domains = <&pwrdm 2>;
		hdmirx_id = <0>;
		en_4k_2_2k = <0>;
		hpd_low_cec_off = <1>;
		arc_port = <2>;
		/* for 2.2R:0x7, for 5.1R:0x6 */
		term_lvl = <0x6>;
		term_lvl_t3x_21 = <0x7>;
		vrr_range_dynamic_update_en = <1>;
		/* bit4: enable feature, bit3~0: port number */
		disable_port = <0x0>;
		/* MAP_ADDR_MODULE_CBUS */
		/* MAP_ADDR_MODULE_HIU */
		/* MAP_ADDR_MODULE_HDMIRX_CAPB3 */
		/* MAP_ADDR_MODULE_SEC_AHB */
		/* MAP_ADDR_MODULE_SEC_AHB2 */
		/* MAP_ADDR_MODULE_APB4 */
		/* MAP_ADDR_MODULE_TOP */
		/* MAP_ADDR_MODULE_CLK_CTRL */
		/* MAP_ADDR_MODULE_ANA_CTRL */
		/* MAP_ADDR_MODULE_COR */
		/* MAP_ADDR_MODULE_EE_VOLTAGE */
		reg = < 0x0 0x0 0x0 0x0
			0x0 0x0 0x0 0x0
			0x0 0x0 0x0 0x0
			0x0 0x0 0x0 0x0
			0x0 0x0 0x0 0x0
			0x0 0x0 0x0 0x0
			0x0 0xfe390000 0x0 0x20000
			0x0 0xfe000000 0x0 0x2ffff
			0x0 0xfe008000 0x280 0x334
			0x0 0x0 0x0 0x0
			0x0 0xfe058000 0x0 0x4>;
	};

	aml_vpq: aml_vpq {
		compatible = "amlogic, vpq-t6x";
		dev_name = "aml_vpq";
		status = "disabled";
	};
};

&periphs_pinctrl {
	emmc_pins: emmc {
		mux-0 {
			groups = "emmc_d0",
				 "emmc_d1",
				 "emmc_d2",
				 "emmc_d3",
				 "emmc_d4",
				 "emmc_d5",
				 "emmc_d6",
				 "emmc_d7",
				 "emmc_cmd";
			function = "emmc";
			bias-pull-up;
			drive-strength-microamp = <3000>;
		};

		mux-1 {
			groups = "emmc_clk";
			function = "emmc";
			bias-disable;
			drive-strength-microamp = <3000>;
		};
	};

	emmc_ds_pins: emmc-ds {
		mux {
			groups = "emmc_ds";
			function = "emmc";
			bias-pull-down;
			drive-strength-microamp = <3000>;
		};
	};

	emmc_clk_gate_pins: emmc_clk_gate {
		mux {
			groups = "GPIOB_8";
			function = "gpio_periphs";
			bias-pull-down;
			drive-strength-microamp = <3000>;
		};
	};

	/* sdemmc portB */
	sd_clk_cmd_pins:sd_clk_cmd_pins {
		mux {
			groups = "sdcard_cmd_c";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
		mux1 {
			groups = "sdcard_clk_c";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	sd_all_pins:sd_all_pins {
		mux {
			groups = "sdcard_d0_c",
				   "sdcard_d1_c",
				   "sdcard_d2_c",
				   "sdcard_d3_c",
				   "sdcard_cmd_c";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
		mux1 {
			groups = "sdcard_clk_c";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	sd_clk_gate_pins: sd_clk_gate {
		mux {
			groups = "GPIOC_4";
			function = "gpio_periphs";
			bias-pull-down;
			drive-strength-microamp = <4000>;
		};
	};

	sd_all_pd_pins:sd_all_pd_pins {
		mux {
			groups = "GPIOC_0",
				   "GPIOC_1",
				   "GPIOC_2",
				   "GPIOC_3",
				   "GPIOC_4",
				   "GPIOC_5";
			function = "gpio_periphs";
			bias-pull-down;
			output-low;
		};
	};

	sd_1bit_pins:sd_1bit_pins {
		mux {
			groups = "sdcard_d0_c",
					"sdcard_cmd_c";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
		mux1 {
			groups = "sdcard_clk_c";
			function = "sdcard";
			bias-pull-up;
			drive-strength-microamp = <4000>;
		};
	};

	hdmirx_a_mux:hdmirx_a_mux {
		mux {
			groups = "hdmirx_hpd_a",
				"hdmirx_5vdet_a",
				"hdmirx_sda_a",
				"hdmirx_scl_a";
			function = "hdmirx";
		};
	};

	hdmirx_b_mux:hdmirx_b_mux {
		mux {
			groups = "hdmirx_hpd_b",
				"hdmirx_5vdet_b",
				"hdmirx_sda_b",
				"hdmirx_scl_b";
			function = "hdmirx";
		};
	};

	hdmirx_c_mux:hdmirx_c_mux {
		mux {
			groups = "hdmirx_hpd_c",
				"hdmirx_5vdet_c",
				"hdmirx_sda_c",
				"hdmirx_scl_c";
			function = "hdmirx";
		};
	};

	hdmirx_d_mux:hdmirx_d_mux {
		mux {
			groups = "hdmirx_hpd_d",
				"hdmirx_5vdet_d",
				"hdmirx_sda_d",
				"hdmirx_scl_d";
			function = "hdmirx";
		};
	};

	cec_b: cec_b {
		mux {
			groups = "cec";
			function = "cec";
		};
	};

	irblaster_pins1:irblaster_pin1 {
		mux {
			groups = "ir_out";
			function = "ir_out";
		};
	};

	irblaster_pins2:irblaster_pin2 {
		mux {
			groups = "ir_out_b";
			function = "ir_out";
		};
	};

	irblaster_pins3:irblaster_pin3 {
