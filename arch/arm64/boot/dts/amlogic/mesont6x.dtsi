		mux {/*only use out, don't support */
			groups = "diseqc_out_z";
			function = "diseqc";
			bias-pull-down;
		};
	};

	spicc0_pins_h: spicc0_pins_h {
		mux {
			groups = "spi_mosi_a",
				 "spi_miso_a",
				 "spi_ss0_a",
				 "spi_clk_a";
			function = "spi";
			drive-strength-microamp = <3000>;
		};
	};

