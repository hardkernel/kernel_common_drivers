	meson-cpufreq {
		compatible = "amlogic, aml-cpufreq";
		status = "okay";

		cluster0-cpu-supply = <&vddcpu0_board2>;

		cluster0 {
			clocks = <&scmi_clk CLKID_CPU_CLK>, <&scmi_clk CLKID_DSU_CLK>;
			clock-names = "cpuclk", "dsuclk";
			voltage-tolerance = <0>;
			clock-latency = <50000>;
			//skip_volt_scaling;
			cluster_cores = <0 1 2 3>;
			pdvfs_enabled;
			dsu-opp-table = <1200000 1000000>,
					 <1404000 1128000>,
					 <1608000 1296000>,
					 <1800000 1440000>,
					 <2004000 1608000>,
					 <2208000 1800000>,
					 <2304000 1848000>,
					 <2400000 1920000>;
		};
	};

	update-pdvfs {
		status = "disabled";
		supply = <&vddcpu0_board0>;
		operating-points-v2 = <&cpu_opp_table1_2000>,
						<&cpu_opp_table2_2000>,
						<&cpu_opp_table3_2000>;
	};
};/* end of / */

