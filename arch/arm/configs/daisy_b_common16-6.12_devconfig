# amlogic-soc-amfc.ko
CONFIG_AMLOGIC_AMFC=m
CONFIG_AMFC_T6D=y
CONFIG_AMFC_BASE=0xFE092000

# amlogic-soc-erofs.ko
CONFIG_AMLOGIC_EROFS=m
CONFIG_AMLOGIC_EROFS_PCPU_KTHREAD=y
CONFIG_AMLOGIC_EROFS_PCPU_KTHREAD_HIPRI=y

# daisy 1g not need
CONFIG_AMLOGIC_MEDIA_VICP=n
CONFIG_AMLOGIC_ION=n
CONFIG_AMLOGIC_ION_DEV=n
CONFIG_AMLOGIC_ION_SYSTEM_HEAP=n
CONFIG_AMLOGIC_VOUT2_SERVE=n
CONFIG_AMLOGIC_LCD_EXTERN_I2C_OLED=n
CONFIG_AMLOGIC_BL_LDIM=n
CONFIG_AMLOGIC_BL_LDIM_IW7027=n
CONFIG_AMLOGIC_BL_LDIM_BLMCU=n
CONFIG_AMLOGIC_MEDIA_VRR=n
CONFIG_AMLOGIC_POST_PROCESS_MANAGER=n
CONFIG_AMLOGIC_MEDIA_ENHANCEMENT_DOLBYVISION=n
CONFIG_AMLOGIC_MEDIA_FRAME_SYNC=n
CONFIG_AMLOGIC_DI_V4L=n
CONFIG_AMLOGIC_MEDIA_FRC=n
CONFIG_AMLOGIC_MEDIA_GDC=n
CONFIG_AMLOGIC_MEDIA_TVIN_DSC_DEC=n
CONFIG_AMLOGIC_MEDIA_TVIN_CSI=n
CONFIG_AMLOGIC_TVIN_USE_DEBUG_FILE=n
CONFIG_AMLOGIC_MEDIA_MSYNC=n
