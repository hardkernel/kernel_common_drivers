	meson-cpufreq {
		compatible = "amlogic, aml-cpufreq-v2";
		status = "okay";

		cluster0-cpu-supply = <&vddcpu0>;

		cluster0 {
			clocks = <&scmi_clk CLKID_SCMI_CPU_CLK>, <&scmi_clk CLKID_SCMI_DSU_CLK>;
			clock-names = "cpuclk", "dsuclk";
			voltage-tolerance = <0>;
			clock-latency = <50000>;
			//skip_volt_scaling;
			cluster_cores = <0 1 2 3>;
			pdvfs_enabled;
			dsu-opp-table = <1200000 1000000>,
					<1404000 1128000>,
					<1608000 1296000>,
					<1800000 1440000>,
					<2004000 1872000>,
					<2400000 2004000>;
		};
	};
