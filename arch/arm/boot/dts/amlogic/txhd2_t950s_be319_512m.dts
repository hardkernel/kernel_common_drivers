/dts-v1/;

#include "mesontxhd2.dtsi"
#include "hdr10plus.dtsi"
#include "mesontxhd2_panel.dtsi"
#include "partition_mbox_normal_txhd2_P_32.dtsi"

/ {
	amlogic-dt-id = "txhd2_t950s_be319-512m";
	compatible = "txhd2_t950s_be319-512m";
	interrupt-parent = <&gic>;
	#address-cells = <1>;
	#size-cells = <1>;

	aliases {
		serial0 = &uart_AO;
		serial1 = &uart_A;
		serial2 = &uart_B;
		serial3 = &uart_C;
		serial4 = &uart_AO_B;
		i2c0 = &i2c0;
		i2c1 = &i2c1;
		i2c2 = &i2c2;
		i2c3 = &i2c3;
		i2c4 = &i2c_AO;
		spi0 = &spicc0;
	};

	memory@0 {
		device_type = "memory";
		linux,usable-memory = <0x00000000 0x20000000>;
	};

	reserved-memory {
		#address-cells = <1>;
		#size-cells = <1>;
		ranges;

		ramdump_bl33z {
			compatible = "shared-dma-pool";
			size = <0x01800000>;
			alignment = <0x00400000>;
			alloc-ranges = <0x05000000 0x07000000>;
			linux,contiguous-region;
			no-map;
			status = "disabled";
		};

		ramdump_data@0 {
			reg = <0x0 0x0>;
			status = "disabled"; /* disabled as default */
		};

		/* global autoconfigured region for contiguous allocations */
		ramoops@6700000 {
			compatible = "ramoops";
			reg = <0x06700000 0x00080000>;/* addr set in uboot */
			record-size = <0x30000>;
			console-size = <0x40000>;
			ftrace-size = <0x0>;
			pmsg-size = <0x10000>;
		};

		dmc_reserved:linux,dmc_monitor {
			compatible = "amlogic,dmc_monitor-reserved";
			reg = <0x0 0x0>;
		};

		debug_reserved:linux,iotrace {
			compatible = "amlogic, iotrace";
			reg = <0x04f00000 0x00100000>;
			io-size = <0x1b000>;
			sched-size = <0x2000>;
			irq-size = <0x1000>;
			smc-size = <0x1000>;
			misc-size = <0x1000>;
		};

		defendkey_reserved:linux,defendkey {
			compatible = "amlogic, defendkey";
			reg = <0x04e00000 0x100000>;
		};

		secmon_reserved:linux,secmon {
			compatible = "shared-dma-pool";
			no-map;
			alignment = <0x100000>;
			reg = <0x05000000 0x01700000>;
		};

		/*  POST PROCESS MANAGER */
		ppmgr_reserved:linux,ppmgr {
			compatible = "shared-dma-pool";
			size = <0x0>;
		};

		picdec_cma_reserved:linux,picdec {
			compatible = "shared-dma-pool";
			status = "disabled";
			reusable;
			size = <0x0>;
			alignment = <0x0>;
			linux,contiguous-region;
		};

		ion_cma_reserved:linux,ion-dev {
			compatible = "shared-dma-pool";
			reusable;
			/* 720p TV androidP size 12M */
			size = <0xc00000>;
			alignment = <0x400000>;
		};

		ion_fb_reserved:linux,ion-fb {
			compatible = "shared-dma-pool";
			reusable;
			size = <0x0>;
			alignment = <0x400000>;
		};

		logo_reserved:linux,meson-fb {
			compatible = "amlogic, meson-fb";
			alignment = <0x400000>;
			reg = <0x1f800000 0x400000>;
		};

		lcd_cma_reserved:linux,lcd-reserved {
			compatible = "amlogic, lcd_rsvd";
			reg = <0x1f000000 0x00410000>;
			tcon-size = <0x00402840>;
		};

		/*  vdin0 CMA pool */
		/*vdin0_cma_reserved:linux,vdin0_cma {*/
		/*	compatible = "shared-dma-pool";*/
		/*	reusable;*/
		/* up to 1920x1080 yuv422 8bit and 5 buffers
		 * 1920x1080x2x5 = 20 M
		 */
		/*	size = <0x0 0x01400000>;*/
		/*	alignment = <0x400000>;*/
		/*};*/
		/*  vdin1 CMA pool */
		vdin1_cma_reserved:linux,vdin1_cma {
			compatible = "shared-dma-pool";
			reusable;
			/* up to 1280x720 yuv422 8bit and 4 buffers
			 * 1280x720x2x4 = 8 M
			 * size = <0x800000>;
			 */
			size = <0x800000>;
			alignment = <0x400000>;
			alloc-ranges = <0x0 0x3f000000>;
		};

		codec_mm_cma:linux,codec_mm_cma {
			compatible = "shared-dma-pool";
			reusable;
			/* ion_codec_mm max can alloc size 80M */
			size = <0x7c00000>;
			alignment = <0x400000>;
			linux,contiguous-region;
		};

		/* codec shared reserved */
		codec_mm_reserved:linux,codec_mm_reserved {
			compatible = "amlogic, codec-mm-reserved";
			size = <0x0>;
			alignment = <0x100000>;
			//no-map;
		};

		secure_vdec_reserved:linux,secure_vdec_reserved {
			compatible = "amlogic, secure-vdec-reserved";
			no-map;
			size = <0x400000>;
			alignment = <0x100000>;
		};

		/* global autoconfigured region for contiguous allocations */
		linux,cma {
			compatible = "shared-dma-pool";
			reusable;
			size = <0x400000>;
			alignment = <0x400000>;
			linux,cma-default;
		};
	};

	usb_b5v_reg: fixed@usb_b5v_reg{
		vin-supply = <&vcc5v_reg>;
		compatible = "regulator-fixed";
		regulator-name = "USB_B_5V";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		regulator-boot-on;
		regulator-always-on;
	};

	usb_c5v_reg: fixed@usb_c5v_reg{
		vin-supply = <&vcc5v_reg>;
		compatible = "regulator-fixed";
		regulator-name = "USB_C_5V";
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		regulator-boot-on;
		regulator-always-on;
	};

	ddr2v5_reg: fixed@ddr2v5_reg{
		vin-supply = <&vddao3v3_reg>;
		compatible = "regulator-fixed";
		regulator-name = "DDR4_2V5";
		regulator-min-microvolt = <2500000>;
		regulator-max-microvolt = <2500000>;
		gpio = <&gpio_test GPIO_TEST_N GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-boot-on;
		regulator-always-on;
	};

	vcc3v3_reg: fixed@vcc3v3_reg{
		vin-supply = <&vddao3v3_reg>;
		compatible = "regulator-fixed";
		regulator-name = "VCC_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&gpio_ao GPIOAO_2 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-boot-on;
		regulator-always-on;
	};

	vdd3v3_reg: fixed@vdd3v3_reg{
		vin-supply = <&vddao3v3_reg>;
		compatible = "regulator-fixed";
		regulator-name = "VDD_3V3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&gpio_test GPIO_TEST_N GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-boot-on;
		regulator-always-on;
	};

	avdd0v9_reg: fixed@avdd0v9_reg{
		vin-supply = <&vcc3v3_reg>;
		compatible = "regulator-fixed";
		regulator-name = "AVDD0V9";
		regulator-min-microvolt = <900000>;
		regulator-max-microvolt = <900000>;
		regulator-boot-on;
		regulator-always-on;
	};

	avdd1v8_reg: fixed@avdd1v8_reg{
		vin-supply = <&vcc3v3_reg>;
		compatible = "regulator-fixed";
		regulator-name = "AVDD1V8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-boot-on;
		//regulator-always-on;
	};

	vdd1v8_boot_reg: fixed@vdd1v8_boot_reg{
		vin-supply = <&vcc3v3_reg>;
		compatible = "regulator-fixed";
		regulator-name = "VDD18_BOOT";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-boot-on;
		//regulator-always-on;
	};

	vdd1v8_reg: fixed@vdd1v8_reg{
		vin-supply = <&vdd3v3_reg>;
		compatible = "regulator-fixed";
		regulator-name = "VDD_1V8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-boot-on;
		//regulator-always-on;
	};

	multi-di {
		post-wr-support = <0>;
		postlink_en = <1>;
	};

	/* for external keypad */
	adc_keypad {
		compatible = "amlogic, adc_keypad";
		status = "okay";
		key_name = "power", "vol-", "vol+", "ok";
		key_num = <4>;
		io-channels = <&saradc SARADC_CH2>;
		io-channel-names = "key-chan-2";
		key_chan = <SARADC_CH2 SARADC_CH2 SARADC_CH2 SARADC_CH2>;
		key_code = <KEY_POWER KEY_VOLUMEDOWN KEY_VOLUMEUP KEY_ENTER>;
		key_val = <0 252 468 684>; // Unit: millivolt
		key_tolerance = <70 70 70 70>; // Unit: millivolt
	};

	atv-demod {
		compatible = "amlogic, atv-demod";
		status = "okay";
		btsc_sap_mode = <1>;
		interrupts = <0 236 1>;
		//pinctrl-names="atvdemod_agc_pins";
		//pinctrl-0=<&atvdemod_agc_pins>;
		reg = <0xff656000 0x2000    // demod reg
				0xff646000 0x2000   // clktree reg
				0x0 0x0             // periphs reg
				0xff64a000 0x2000>; // adec reg
		//common_agc = <1>;
	};

	aml_dtv_demod {
		compatible = "amlogic, ddemod-txhd2";
		dev_name = "aml_dtv_demod";
		status = "okay";
		//pinctrl-names="if_agc_pins";
		//pinctrl-0=<&dtvdemod_if_agc_pins>;
		power-domains = <&pwrdm PDID_DEMOD>;
		reg = <0xff670000 0x10000 //dtv demod base
				0xff646000 0x2000 //clktree reg base
				0xff800000 0x1000 //io_aobus_base
				0xffd01000 0x2000>; //system reset

		cma_mem_size = <8>; // MB
	};

	dvb-extern {
		compatible = "amlogic, dvb-extern";
		dev_name = "dvb-extern";
		status = "okay";

		fe_num = <1>;
		fe0_demod = "internal";

		tuner_num = <1>; // tuner number, multi tuner support
		tuner0_name = "mxl661_tuner";
		tuner0_i2c_adap = <&i2c1>;
		tuner0_i2c_addr = <0x60>; // 8 bits
		tuner0_xtal = <0>;       // 0: 16MHz, 1: 24MHz
		tuner0_xtal_mode = <0>;
		tuner0_xtal_cap = <25>;
	};

	dvb-demux {
		compatible = "amlogic, dvb-demux";
		dev_name = "dvb-demux";
		status = "okay";

		dmx = <&demux>;
		key_endia = <1>;
		add_s2p2 = <1>;
		add_ts_in = <1>;
		add_asyncfifo = <1>;

		/*"parallel","serial","disable"*/
		ts2 = "parallel";
		ts2_control = <0>;
		ts2_invert = <0>;
		tsin_deglitch = <1>;

		clocks = <&clkc CLKID_CLK81_DMUX
		&clkc CLKID_CLK81_AHB_ARB0
		&clkc CLKID_CLK81_PARSER>;
		clock-names = "demux", "ahbarb0", "parser_top";
		//pinctrl-names = "p_ts2";
		//pinctrl-0 = <&dvb_p_ts2_pins>;
	};
}; /* end of / */

&hdmirx {
	status = "okay";
	en_4k_2_2k = <0>;
	hpd_low_cec_off = <1>;
	arc_port = <1>;
	/* bit4: enable feature, bit3~0: port number */
	disable_port = <0x0>;
	pinctrl-0 = <&hdmirx_a_mux &hdmirx_b_mux>;
};

&picdec {
	status = "disabled";
};

&pinctrl_periphs {
	/*backlight*/
	bl_pwm_vs_on_pins:bl_pwm_vs_on_pin {
		mux {
			groups = "pwm_vs_z1";
			function = "pwm_vs";
		};
	};
	bl_pwm_off_pins:bl_pwm_off_pin {
		mux {
			groups = "GPIOZ_1";
			function = "gpio_periphs";
			output-low;
		};
	};
};

&i2c1 {
	status = "okay";
	clock-frequency = <300000>;
	pinctrl-names="default";
	pinctrl-0=<&i2c1_pins1>;
};

&sd_emmc_c {
	status = "okay";
	run-low-mem;
	pinctrl-0 = <&emmc_pins>, <&emmc_ds_pins>;
	pinctrl-1 = <&emmc_clk_gate_pins>;
	pinctrl-names = "default", "clk-gate";

	bus-width = <8>;
	cap-sd-highspeed;
	cap-mmc-highspeed;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	max-frequency = <200000000>;
	non-removable;
	disable-wp;

//  mmc-pwrseq = <&emmc_pwrseq>;
//  vmmc-supply = <&vddao_3v3>;
//  vqmmc-supply = <&vddao_1v8>;
};

&meson_fb {
	status = "okay";
	display_size_default = <1280 720 1280 2160 32>;
	mem_size = <0x00400000 0xb00000 0x100000>;
	logo_addr = "0x3f800000";
	mem_alloc = <0>;
	pxp_mode = <0>; /** 0:normal mode 1:pxp mode */
};

&uart_AO {
	status = "okay";
};

&usbphy0 {
	status = "okay";
	u2p@0 {
		status = "okay";
		controller-type = <1>; /* 0~3: normal, host, device, otg */
	};
};

&usbphy1 {
	status = "okay";
	u2p@0 {
		status = "okay";
		gpio-vbus-power = "GPIODV_7";
		gpios = <&gpio GPIODV_7 GPIO_ACTIVE_HIGH>;
	};

	u2p@20 {
		status = "okay";
	};
};

&crg20_drd {
	status = "okay";
};

&crg_udc_2 {
	status = "okay";
};

&crg2_drd {
	status = "okay";
};

&saradc {
	status = "okay";
};

&spicc0 {
	status = "disabled";
	pinctrl-names = "default";
	pinctrl-0 = <&spicc0_pins_c>;
	cs-gpios = <&gpio GPIOC_7 GPIO_ACTIVE_HIGH>;
	assigned-clocks = <&clkc CLKID_SPICC0>;
	assigned-clock-parents = <&clkc CLKID_FCLK_DIV2>;
	assigned-clock-rates = <200000000>;
	parent_clk_fixed;
};

&amlvecm {
	status = "okay";
	gamma_en = <1>;/*1:enable ;0:disable*/
	wb_en = <1>;/*1:enable ;0:disable*/
	cm_en = <1>;/*1:enable ;0:disable*/
	wb_sel = <0>;/*1:mtx ;0:gainoff*/
	vlock_en = <1>;/*1:enable;0:disable*/
	vlock_mode = <0x8>;
	vrr_priority = <1>;/*1:game mode vrr always on;0:vrr on depend on vrr signal*/
	/*vlock work mode:
	 *bit0:auto ENC
	 *bit1:auto PLL
	 *bit2:manual PLL
	 *bit3:manual ENC
	 *bit4:manual soft ENC
	 *bit5:manual MIX PLL ENC
	 */
	vlock_pll_m_limit = <1>;
	vlock_line_limit = <2>;
	interrupts = <0 87 1>;
	interrupt-names = "lc_curve";
};

/*if you want to use vdin just modify status to "ok"*/
&vdin0 {
	/*memory-region = <&vdin0_cma_reserved>;*/
	status = "okay";
	/*MByte, if 10bit disable: 64M(YUV422),
	 *if 10bit enable: 64*1.5 = 96M(YUV422)
	 *if support 4K2K-YUV444-10bit-WR:3840*2160*4*4 ~= 128M
	 *if support 4K2K-YUV422-10bit-wr:3840*2160*3*4 ~= 96M
	 *if support 4K2K-YUV422-8BIT-WR:3840*2160*2*4 ~= 64M
	 *if support 1080p-YUV422-8BIT-WR:1920*1080*2*4 ~= 16M
	 * onebuffer:
	 * worst case:(4096*2160*3 + 2M(afbce issue)) = 27.5M
	 * dw:960x540x3 = 1.5M
	 * total size:(27.5+1.5)x buffernumber
	 */
	cma_size = <80>;
	frame_buff_num = <10>;
};

&vdin1 {
	memory-region = <&vdin1_cma_reserved>;
	status = "okay";
};
