	cs-gpios = <&gpio GPIOH_8 GPIO_ACTIVE_HIGH>;
	spi-nor@0 {
		compatible = "jedec,spi-nor";
		status = "okay";
		reg = <0>;
		spi-max-frequency = <16000000>;
