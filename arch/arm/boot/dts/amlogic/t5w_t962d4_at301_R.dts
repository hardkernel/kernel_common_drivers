&spicc1 {	//for UWB/LocalDimm
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&spicc1_pins &spicc1_cs_pins>;
	// cs-gpios = <&gpio GPIOH_22 GPIO_ACTIVE_HIGH>;
	cs2clk-us = <2>;
